---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Cost surface">

<!-- ═══ HERO ═══ -->
<section class="max-w-5xl mx-auto px-6 pt-20 pb-12">
  <p class="section-label mb-5">Cost-surface dispatcher</p>
  <h1 class="font-display text-5xl md:text-6xl font-bold text-brand-white leading-[1.05] tracking-tight mb-6">
    A workload, <span class="text-brand-amber italic">routed</span>.
  </h1>
  <p class="text-brand-light text-lg md:text-xl max-w-3xl leading-relaxed">
    tei-fabric reads the Periodic Stack of Computation and dispatches each primitive in a workload to the substrate whose physics performs it at the lowest joule cost. Build a multi-primitive workload below; the dispatcher reports the per-substrate roll-up.
  </p>
</section>

<!-- ═══ DEMO ═══ -->
<section class="max-w-7xl mx-auto px-6 pb-24">
  <div class="grid lg:grid-cols-[460px_1fr] gap-6">

    <!-- ─── FORM ─── -->
    <div class="space-y-5 self-start">

      <!-- import -->
      <div class="glass-card p-6">
        <p class="section-label mb-4">Import ONNX</p>
        <p class="text-brand-gray text-xs leading-relaxed mb-4">
          Drop a real .onnx file — the fabric will parse the graph, map each operator to a Periodic Stack primitive, and populate the invocation list below.
        </p>
        <label class="block">
          <input id="onnx-file" type="file" accept=".onnx,application/octet-stream" style="display: none;" />
          <span id="onnx-file-label" class="block text-center font-mono text-[12px] text-brand-cyan border border-dashed border-brand-cyan/40 px-4 py-3 rounded-md cursor-pointer hover:bg-brand-cyan/5 hover:border-brand-cyan transition-all">
            CHOOSE .onnx FILE →
          </span>
        </label>
        <p id="onnx-status" class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mt-3 text-center" style="display:none;"></p>
      </div>

      <!-- preset -->
      <div class="glass-card p-6">
        <p class="section-label mb-4">Workload preset</p>
        <select id="preset" class="mb-1">
          <option value="" disabled selected>— pick a preset to populate —</option>
          <optgroup label="Single op">
            <option value="attention-matmul">Attention QKV projection (1 matmul, 512×768×2048)</option>
            <option value="small-matmul">Small matmul (32³)</option>
            <option value="dct">DCT 1024² (pure-L₀ transform)</option>
            <option value="hilbert">Hilbert transform 1024²</option>
            <option value="kalman">Kalman filter step (64-state)</option>
            <option value="maxcut">Max-Cut SA (256 vars · 4k sweeps)</option>
            <option value="ising">Ising-EBM Gibbs (1024 p-bits · 10k sweeps)</option>
            <option value="bayes">Bayesian posterior chain (128 vars · 5k samples)</option>
          </optgroup>
          <optgroup label="Multi-primitive blocks">
            <option value="attention-block">One attention block (QKV + QKᵀ + softmax + V + out)</option>
            <option value="transformer-layer">One transformer layer (attention + MLP)</option>
            <option value="transformer-12L">Transformer ×12 layers (full forward)</option>
            <option value="diffusion-step">Diffusion sampler step (UNet matmuls + MCMC denoise)</option>
            <option value="resnet-stage">ResNet stage (3 conv layers + pooling)</option>
          </optgroup>
        </select>
      </div>

      <!-- invocations -->
      <div class="glass-card p-6">
        <div class="flex items-baseline justify-between mb-4">
          <p class="section-label">Invocations</p>
          <button id="add-invocation" class="font-mono text-[11px] text-brand-cyan border border-brand-cyan/30 px-2.5 py-1 rounded hover:bg-brand-cyan/10 cursor-pointer">+ ADD</button>
        </div>
        <div id="invocations" class="space-y-3"></div>
        <p id="invocation-empty" class="text-brand-gray text-sm text-center py-3" style="display: none;">
          No invocations. Pick a preset above or click <strong class="text-brand-cyan">+ ADD</strong>.
        </p>
      </div>

      <!-- constraints + dispatch -->
      <div class="glass-card p-6">
        <p class="section-label mb-4">Constraints</p>
        <div class="grid grid-cols-2 gap-3 mb-5">
          <div>
            <label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">Cycles / sec</label>
            <input id="cps" type="number" value="30" min="1" />
          </div>
          <div>
            <label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">Budget (W)</label>
            <input id="budget" type="number" step="0.1" value="5" min="0.1" />
          </div>
        </div>
        <button id="dispatch-btn" class="primary w-full">DISPATCH →</button>
        <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mt-4 text-center">
          API: <span id="api-base">http://localhost:9651</span>
        </p>
      </div>
    </div>

    <!-- ─── RESULTS ─── -->
    <div id="results" class="space-y-5">
      <div class="glass-card p-10 text-center">
        <p class="section-label mb-4">Awaiting dispatch</p>
        <p class="text-brand-light text-base leading-relaxed">
          Pick a preset to populate the workload, then DISPATCH. The cost-surface runtime will price each invocation across all five substrates and roll up the chosen plan.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════
     INVOCATION CARD CSS
     ═══════════════════════════════════════════════════════════════════ -->
<style is:global>
  .inv-card {
    background: rgba(8, 12, 20, 0.5);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    padding: 14px 16px 12px;
    position: relative;
  }
  .inv-card .remove {
    position: absolute;
    top: 8px;
    right: 10px;
    background: transparent;
    border: none;
    color: var(--color-brand-gray);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
    padding: 4px 6px;
    border-radius: 4px;
  }
  .inv-card .remove:hover {
    color: var(--color-brand-amber);
    background: rgba(245, 158, 11, 0.1);
  }
  .inv-card .primitive-select {
    margin-bottom: 10px;
  }
  .inv-card .field-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-brand-gray);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
    display: block;
  }
  .inv-card input, .inv-card select {
    font-size: 12px;
    padding: 4px 8px;
  }
</style>

<!-- ═══════════════════════════════════════════════════════════════════
     DISPATCH + FORM SCRIPT
     ═══════════════════════════════════════════════════════════════════ -->
<script is:inline>
const API_BASE = (() => {
  const url = new URL(window.location.href);
  return url.searchParams.get('api') || 'http://localhost:9651';
})();
document.getElementById('api-base').textContent = API_BASE;

// ────────────────────────────────────────────────────────────────────
// Catalog: primitive ID → metadata. Mirrors the Rust dialect filters so
// the form can swap fields based on the kind of primitive selected.
// ────────────────────────────────────────────────────────────────────
const PRIMITIVES = [
  // Matmul-class (LA / TR / TEN families with MAC structure)
  { id: 18,  name: 'Dense MatMul',                 kind: 'matmul' },
  { id: 19,  name: 'SpMM / SpMV',                  kind: 'matmul' },
  { id: 20,  name: 'Attention (fused)',            kind: 'matmul' },
  { id: 24,  name: 'Convolution',                  kind: 'matmul' },
  { id: 48,  name: 'Tensor network contraction',   kind: 'matmul' },
  { id: 76,  name: 'Matrix decomposition',         kind: 'matmul' },
  { id: 77,  name: 'Eigendecomposition',           kind: 'matmul' },
  // Linear transforms + elementwise (Bennett-decomposable → reversible-friendly)
  { id: 79,  name: 'DCT (pure-L₀)',                kind: 'scalar' },
  { id: 80,  name: 'Hilbert transform (pure-L₀)',  kind: 'scalar' },
  { id: 34,  name: 'Softmax',                       kind: 'scalar' },
  { id: 35,  name: 'Normalization',                 kind: 'scalar' },
  { id: 26,  name: 'Pooling',                       kind: 'scalar' },
  { id: 109, name: 'Kalman filter step',            kind: 'scalar' },
  { id: 6,   name: 'Sort / rank',                   kind: 'scalar' },
  { id: 36,  name: 'Hash',                          kind: 'scalar' },
  // Sampling-class (L₁ — stochastic-friendly)
  { id: 38,  name: 'Monte Carlo accept/reject',    kind: 'sampling' },
  { id: 39,  name: 'MCMC / Langevin step',         kind: 'sampling' },
  { id: 99,  name: 'Bayesian posterior',           kind: 'sampling' },
  { id: 258, name: 'Simulated annealing',          kind: 'sampling' },
  { id: 251, name: 'Bootstrap resampling',         kind: 'sampling' },
  { id: 245, name: 'Discrete Gaussian sampling',   kind: 'sampling' },
];
const PRIM_BY_ID = Object.fromEntries(PRIMITIVES.map(p => [p.id, p]));

// ────────────────────────────────────────────────────────────────────
// State + render
// ────────────────────────────────────────────────────────────────────
let state = { invocations: [] };
let nextId = 1;

function makeInv(over) {
  return {
    id: nextId++,
    primitive_id: 18,
    count: 1,
    label: '',
    m: 512, k: 768, n: 2048,
    variables: 1024, sweeps: 10000,
    batch: 1, dtype: 'f16',
    ...over,
  };
}

function $(id) { return document.getElementById(id); }

function primitiveOptionsHtml(selectedId) {
  // Group by kind for readability
  const groups = [
    ['Matmul-class', PRIMITIVES.filter(p => p.kind === 'matmul')],
    ['Scalar / transform',  PRIMITIVES.filter(p => p.kind === 'scalar')],
    ['Sampling',     PRIMITIVES.filter(p => p.kind === 'sampling')],
  ];
  return groups.map(([label, prims]) => `
    <optgroup label="${label}">
      ${prims.map(p =>
        `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>${p.id} · ${p.name}</option>`
      ).join('')}
    </optgroup>`).join('');
}

function renderInvocation(inv) {
  const meta = PRIM_BY_ID[inv.primitive_id] || { kind: 'scalar' };
  const matmulFields = `
    <div class="grid grid-cols-3 gap-2 mb-2">
      <div><span class="field-label">m</span>     <input type="number" data-key="m" value="${inv.m}" /></div>
      <div><span class="field-label">k</span>     <input type="number" data-key="k" value="${inv.k}" /></div>
      <div><span class="field-label">n</span>     <input type="number" data-key="n" value="${inv.n}" /></div>
    </div>`;
  const samplingFields = `
    <div class="grid grid-cols-2 gap-2 mb-2">
      <div><span class="field-label">Variables</span> <input type="number" data-key="variables" value="${inv.variables}" /></div>
      <div><span class="field-label">Sweeps</span>    <input type="number" data-key="sweeps" value="${inv.sweeps}" /></div>
    </div>`;
  const profileFields = (meta.kind === 'sampling') ? samplingFields
    : (meta.kind === 'matmul') ? matmulFields
    : ''; // scalar — no shape inputs in v0

  return `
    <div class="inv-card" data-id="${inv.id}">
      <button class="remove" data-action="remove" title="Remove">×</button>
      <span class="field-label">Primitive</span>
      <select class="primitive-select" data-key="primitive_id">
        ${primitiveOptionsHtml(inv.primitive_id)}
      </select>
      ${profileFields}
      <div class="grid grid-cols-[1fr_1.6fr] gap-2 mb-1">
        <div>
          <span class="field-label">Count</span>
          <input type="number" data-key="count" value="${inv.count}" min="1" />
        </div>
        <div>
          <span class="field-label">Label</span>
          <input type="text" data-key="label" value="${inv.label}" placeholder="optional" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <span class="field-label">Batch</span>
          <input type="number" data-key="batch" value="${inv.batch}" min="1" />
        </div>
        <div>
          <span class="field-label">Dtype</span>
          <select data-key="dtype">
            ${['i4','i8','f16','bf16','f32'].map(d => `<option value="${d}" ${inv.dtype === d ? 'selected' : ''}>${d.toUpperCase()}</option>`).join('')}
          </select>
        </div>
      </div>
    </div>`;
}

function renderInvocations() {
  const root = $('invocations');
  root.innerHTML = state.invocations.map(renderInvocation).join('');
  $('invocation-empty').style.display = state.invocations.length === 0 ? '' : 'none';

  // Wire change handlers per card
  root.querySelectorAll('.inv-card').forEach(card => {
    const id = parseInt(card.dataset.id, 10);
    card.querySelector('[data-action="remove"]').addEventListener('click', () => {
      state.invocations = state.invocations.filter(x => x.id !== id);
      renderInvocations();
    });
    card.querySelectorAll('[data-key]').forEach(el => {
      el.addEventListener('change', () => {
        const inv = state.invocations.find(x => x.id === id);
        if (!inv) return;
        let v = el.value;
        if (el.type === 'number') v = parseFloat(v);
        if (el.dataset.key === 'primitive_id') v = parseInt(v, 10);
        inv[el.dataset.key] = v;
        // If the primitive's kind changed (matmul ↔ sampling ↔ scalar),
        // re-render so the right fields show up.
        if (el.dataset.key === 'primitive_id') renderInvocations();
      });
    });
  });
}

function setInvocations(list) {
  state.invocations = list.map(x => makeInv(x));
  renderInvocations();
}

// ────────────────────────────────────────────────────────────────────
// Presets (build a list of invocations for each)
// ────────────────────────────────────────────────────────────────────
function preset(name) {
  const M = (over) => Object.assign({ primitive_id: 18, count: 1, label: '', dtype: 'f16' }, over);
  switch (name) {
    case 'attention-matmul':
      return [M({ label: 'QKV projection', m: 512, k: 768, n: 2048 })];
    case 'small-matmul':
      return [M({ label: 'Small matmul', m: 32, k: 32, n: 32, dtype: 'i8' })];
    case 'dct':
      return [M({ primitive_id: 79, label: 'DCT 1024²', m: 1024, k: 1024, n: 1024 })];
    case 'hilbert':
      return [M({ primitive_id: 80, label: 'Hilbert 1024²', m: 1024, k: 1024, n: 1024 })];
    case 'kalman':
      return [M({ primitive_id: 109, label: 'Kalman 64-state', m: 64, k: 64, n: 64 })];
    case 'maxcut':
      return [M({ primitive_id: 258, label: 'Max-Cut SA', variables: 256, sweeps: 4000, dtype: 'i8' })];
    case 'ising':
      return [M({ primitive_id: 39, label: 'Ising Gibbs', variables: 1024, sweeps: 10000, dtype: 'i8' })];
    case 'bayes':
      return [M({ primitive_id: 99, label: 'Bayesian posterior', variables: 128, sweeps: 5000 })];
    case 'attention-block':
      // GPT-style attention block, dim=768, heads merged, seq=512
      return [
        M({ label: 'WQ projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'WK projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'WV projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'QKᵀ (attention scores)', m: 512, k: 768, n: 512 }),
        M({ primitive_id: 34, label: 'Softmax (per row)', m: 512, k: 1, n: 512, count: 1 }),
        M({ label: 'Attn × V',       m: 512, k: 512, n: 768 }),
        M({ label: 'Output projection', m: 512, k: 768, n: 768 }),
      ];
    case 'transformer-layer':
      // attention block + MLP (4× hidden dim FFN)
      return [
        M({ label: 'WQ projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'WK projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'WV projection',  m: 512, k: 768, n: 768 }),
        M({ label: 'QKᵀ',            m: 512, k: 768, n: 512 }),
        M({ primitive_id: 34, label: 'Softmax', m: 512, k: 1, n: 512 }),
        M({ label: 'Attn × V',       m: 512, k: 512, n: 768 }),
        M({ label: 'Out projection', m: 512, k: 768, n: 768 }),
        M({ primitive_id: 35, label: 'LayerNorm', m: 512, k: 1, n: 768 }),
        M({ label: 'FFN up   (768 → 3072)',   m: 512, k: 768,  n: 3072 }),
        M({ label: 'FFN down (3072 → 768)',   m: 512, k: 3072, n: 768  }),
      ];
    case 'transformer-12L':
      // 12 layers — same as transformer-layer but count=12 for each invocation
      return [
        M({ label: 'WQ × 12L',  m: 512, k: 768, n: 768, count: 12 }),
        M({ label: 'WK × 12L',  m: 512, k: 768, n: 768, count: 12 }),
        M({ label: 'WV × 12L',  m: 512, k: 768, n: 768, count: 12 }),
        M({ label: 'QKᵀ × 12L', m: 512, k: 768, n: 512, count: 12 }),
        M({ primitive_id: 34, label: 'Softmax × 12L', m: 512, k: 1, n: 512, count: 12 }),
        M({ label: 'Attn × V × 12L',       m: 512, k: 512, n: 768, count: 12 }),
        M({ label: 'Out projection × 12L', m: 512, k: 768, n: 768, count: 12 }),
        M({ primitive_id: 35, label: 'LayerNorm × 24L', m: 512, k: 1, n: 768, count: 24 }),
        M({ label: 'FFN up × 12L',   m: 512, k: 768,  n: 3072, count: 12 }),
        M({ label: 'FFN down × 12L', m: 512, k: 3072, n: 768,  count: 12 }),
      ];
    case 'diffusion-step':
      // One denoising step: UNet forward (a few matmuls) + an MCMC denoise op
      return [
        M({ label: 'UNet input proj',  m: 64, k: 4, n: 320 }),
        M({ label: 'UNet middle block', m: 64, k: 320, n: 320 }),
        M({ label: 'UNet output proj', m: 64, k: 320, n: 4 }),
        M({ primitive_id: 39, label: 'MCMC denoise', variables: 256, sweeps: 4096 }),
      ];
    case 'resnet-stage':
      return [
        M({ primitive_id: 24, label: 'Conv 1 (64ch)',  m: 56, k: 64,  n: 56 }),
        M({ primitive_id: 24, label: 'Conv 2 (128ch)', m: 28, k: 128, n: 28 }),
        M({ primitive_id: 24, label: 'Conv 3 (256ch)', m: 14, k: 256, n: 14 }),
        M({ primitive_id: 26, label: 'Pool',           m: 7,  k: 256, n: 7 }),
      ];
  }
  return [];
}

// Built from /api/presets at page load.
const CATALOG_PRESETS = {};

$('preset').addEventListener('change', (e) => {
  const key = e.target.value;
  // Catalog presets win if both define the key.
  if (CATALOG_PRESETS[key]) {
    const w = CATALOG_PRESETS[key];
    setInvocations(w.invocations.map(iv => {
      const dims = (iv.profile.shape && iv.profile.shape.dims) || [];
      const m = dims.length >= 1 ? dims[0] : 512;
      const n = dims.length >= 2 ? dims[1] : 2048;
      return {
        primitive_id: iv.primitive_id,
        count: iv.count,
        label: iv.label,
        batch: iv.profile.batch || 1,
        dtype: iv.profile.dtype || 'f16',
        m, k: iv.profile.reduce_dim || 768, n,
        variables: iv.profile.variables || 1024,
        sweeps:    iv.profile.sweeps    || 10000,
      };
    }));
    return;
  }
  const list = preset(key);
  if (list.length === 0) return;
  setInvocations(list);
});

// Fetch catalog-driven presets and append them to the dropdown.
async function loadCatalogPresets() {
  try {
    const res = await fetch(`${API_BASE}/api/presets`);
    if (!res.ok) return;
    const presets = await res.json();
    const select = $('preset');
    // Group by `category`.
    const groups = {};
    for (const p of presets) {
      (groups[p.category] ||= []).push(p);
      CATALOG_PRESETS[p.key] = p.workload;
    }
    for (const [cat, list] of Object.entries(groups)) {
      const grp = document.createElement('optgroup');
      grp.label = cat;
      for (const p of list) {
        const opt = document.createElement('option');
        opt.value = p.key;
        opt.textContent = p.label;
        opt.title = p.description;
        grp.appendChild(opt);
      }
      select.appendChild(grp);
    }
  } catch (_) { /* silent — static presets still work */ }
}

$('add-invocation').addEventListener('click', () => {
  state.invocations.push(makeInv({ label: '' }));
  renderInvocations();
});

// ────────────────────────────────────────────────────────────────────
// Dispatch + result rendering
// ────────────────────────────────────────────────────────────────────
function fmtJoules(j) {
  if (j === 0) return '0 J';
  const a = Math.abs(j);
  if (a >= 1)      return j.toExponential(3) + ' J';
  if (a >= 1e-3)  return (j * 1e3).toFixed(3) + ' mJ';
  if (a >= 1e-6)  return (j * 1e6).toFixed(3) + ' µJ';
  if (a >= 1e-9)  return (j * 1e9).toFixed(3) + ' nJ';
  if (a >= 1e-12) return (j * 1e12).toFixed(3) + ' pJ';
  if (a >= 1e-15) return (j * 1e15).toFixed(3) + ' fJ';
  return j.toExponential(3) + ' J';
}
function fmtPower(w) {
  if (w === 0) return '0 W';
  const a = Math.abs(w);
  if (a >= 1)      return w.toFixed(3) + ' W';
  if (a >= 1e-3)  return (w * 1e3).toFixed(3) + ' mW';
  if (a >= 1e-6)  return (w * 1e6).toFixed(3) + ' µW';
  if (a >= 1e-9)  return (w * 1e9).toFixed(3) + ' nW';
  return w.toExponential(3) + ' W';
}
function fmtTime(s) {
  if (s === 0) return '0 s';
  const a = Math.abs(s);
  if (a >= 1)      return s.toFixed(3) + ' s';
  if (a >= 1e-3)  return (s * 1e3).toFixed(3) + ' ms';
  if (a >= 1e-6)  return (s * 1e6).toFixed(3) + ' µs';
  if (a >= 1e-9)  return (s * 1e9).toFixed(3) + ' ns';
  return s.toExponential(3) + ' s';
}
function colorForSubstrate(name) {
  switch (name) {
    case 'baseline':   return 'cyan';
    case 'photonic':   return 'violet';
    case 'in-memory':  return '';      // amber default
    case 'stochastic': return 'gold';
    case 'reversible': return 'emerald';
    default:           return '';
  }
}

function buildInvocationPayload(inv) {
  const meta = PRIM_BY_ID[inv.primitive_id] || { kind: 'scalar' };
  let profile = { batch: inv.batch | 0, dtype: inv.dtype };
  if (meta.kind === 'sampling') {
    profile.shape = { dims: [inv.variables | 0] };
    profile.sweeps = inv.sweeps | 0;
    profile.variables = inv.variables | 0;
  } else if (meta.kind === 'matmul') {
    profile.shape = { dims: [inv.m | 0, inv.n | 0] };
    profile.reduce_dim = inv.k | 0;
  } else {
    // scalar / transform — pass shape if user filled it (m×n×k) so substrates
    // that interpret it as matmul-like get a sensible MAC count.
    profile.shape = { dims: [inv.m | 0, inv.n | 0] };
    profile.reduce_dim = inv.k | 0;
  }
  return {
    primitive_id: inv.primitive_id,
    count: inv.count | 0,
    label: inv.label || '',
    profile,
  };
}

async function dispatch() {
  if (state.invocations.length === 0) {
    $('results').innerHTML = `
      <div class="glass-card p-8" style="border-color: rgba(245,158,11,0.3);">
        <p class="section-label mb-3" style="color: var(--color-brand-amber);">Empty workload</p>
        <p class="text-brand-light text-sm">Pick a preset or click <strong>+ ADD</strong> to populate the invocation list.</p>
      </div>`;
    return;
  }

  const btn = $('dispatch-btn');
  btn.disabled = true;
  btn.textContent = 'DISPATCHING…';

  const body = {
    goal: `${state.invocations.length} invocation${state.invocations.length === 1 ? '' : 's'}`,
    invocations: state.invocations.map(buildInvocationPayload),
    constraints: {
      cycles_per_second: parseFloat($('cps').value),
      power_budget_w: parseFloat($('budget').value),
      volume: 10000,
    },
  };

  try {
    const res = await fetch(`${API_BASE}/api/dispatch`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    renderPlan(await res.json());
  } catch (e) {
    $('results').innerHTML = `
      <div class="glass-card p-8" style="border-color: rgba(239,68,68,0.3);">
        <p class="section-label mb-3" style="color: #ef4444;">Dispatch failed</p>
        <p class="text-brand-light font-mono text-sm">${e.message}</p>
        <p class="text-brand-gray text-sm mt-3">Is <code>tei-serve</code> running on ${API_BASE}? Start it with <code>cargo run -p tei-serve</code> from the workspace root.</p>
      </div>`;
  } finally {
    btn.disabled = false;
    btn.textContent = 'DISPATCH →';
  }
}

function renderPlan(plan) {
  const root = $('results');
  const savings = plan.savings_factor;
  const within = plan.within_budget;

  // headline
  const headline = `
    <div class="glass-card p-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="section-label mb-3">Joules saved</p>
          <p class="font-display text-5xl font-bold text-brand-amber italic">${savings.toFixed(0)}<span class="text-3xl">×</span></p>
          <p class="text-brand-gray text-xs font-mono mt-2 tracking-wider uppercase">vs CPU/GPU baseline</p>
        </div>
        <div>
          <p class="section-label mb-3">Power @ ${$('cps').value} Hz</p>
          <p class="font-display text-4xl font-bold text-brand-white">${fmtPower(plan.power_w)}</p>
          <p class="text-brand-gray text-xs font-mono mt-2 tracking-wider uppercase">baseline: ${fmtPower(plan.baseline_power_w)}</p>
        </div>
        <div>
          <p class="section-label mb-3">Budget</p>
          <p class="font-display text-4xl font-bold ${within ? 'text-brand-cyan' : 'text-brand-amber'}">${within ? 'WITHIN' : 'OVER'}</p>
          <p class="text-brand-gray text-xs font-mono mt-2 tracking-wider uppercase">limit ${fmtPower(plan.power_budget_w)}</p>
        </div>
      </div>
    </div>`;

  // per-substrate aggregate bars
  const maxJ = Math.max(
    ...plan.per_substrate_joules.map(s => s.joules),
    plan.baseline_total_joules,
    1e-30,
  );
  const aggBars = plan.per_substrate_joules.map(s => {
    const pct = (s.joules / maxJ * 100).toFixed(2);
    return `
      <div>
        <div class="flex items-baseline justify-between mb-1.5">
          <span class="font-mono text-[12px] text-brand-light">${s.display}</span>
          <span class="font-mono text-[11px] text-brand-amber">${fmtJoules(s.joules)} · ${s.op_count} op${s.op_count === 1 ? '' : 's'}</span>
        </div>
        <div class="bar-track"><div class="bar-fill ${colorForSubstrate(s.substrate)}" style="width: ${pct}%"></div></div>
      </div>`;
  }).join('');
  const baselinePct = (plan.baseline_total_joules / maxJ * 100).toFixed(2);
  const aggregate = `
    <div class="glass-card p-7">
      <p class="section-label mb-5">Cost surface · joules by substrate</p>
      <div class="space-y-4">
        ${aggBars}
        <div class="pt-4 border-t border-brand-border">
          <div class="flex items-baseline justify-between mb-1.5">
            <span class="font-mono text-[12px] text-brand-gray uppercase tracking-wider">Baseline only (if dispatched everywhere)</span>
            <span class="font-mono text-[11px] text-brand-gray">${fmtJoules(plan.baseline_total_joules)}</span>
          </div>
          <div class="bar-track"><div class="bar-fill cyan" style="width: ${baselinePct}%; opacity: 0.4;"></div></div>
        </div>
      </div>
    </div>`;

  // per-invocation cards
  const invs = plan.assignments.map(a => {
    const considered = a.considered.map(o => {
      const supportedTag = o.supported
        ? `<span class="text-brand-amber">${fmtJoules(o.joules_total)}</span>`
        : `<span class="text-brand-gray">— not supported</span>`;
      const chosenBadge = o.substrate === a.chosen_substrate
        ? `<span class="font-mono text-[10px] text-brand-amber bg-brand-amber/10 border border-brand-amber/30 px-1.5 py-0.5 rounded">CHOSEN</span>`
        : '';
      return `
        <div class="flex items-baseline justify-between py-1.5 border-b border-brand-border last:border-b-0">
          <span class="font-mono text-[12px] text-brand-light flex items-center gap-2">${o.display} ${chosenBadge}</span>
          <span class="font-mono text-[11px]">${supportedTag}</span>
        </div>`;
    }).join('');

    return `
      <div class="glass-card p-7">
        <div class="flex items-baseline justify-between mb-2 flex-wrap gap-3">
          <div>
            <p class="font-mono text-[10px] text-brand-amber tracking-wider uppercase mb-1">${a.primitive_id} · ${a.family} · ${a.thermo} · ×${a.count}</p>
            <h3 class="font-display text-xl font-bold text-brand-white">${a.primitive_name}</h3>
          </div>
          <div class="text-right">
            <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider">Dispatched to</p>
            <p class="font-display text-base font-bold text-brand-amber italic">${a.chosen_display}</p>
          </div>
        </div>
        ${a.label ? `<p class="text-brand-gray text-sm mb-3">${a.label}</p>` : ''}
        <p class="text-brand-light text-sm mb-4"><span class="text-brand-amber">→</span> ${a.justification}</p>

        <p class="section-label mb-2 text-[10px]">Considered set</p>
        <div>${considered}</div>

        <div class="grid grid-cols-3 gap-4 mt-4 pt-4 border-t border-brand-border">
          <div>
            <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1">J / op</p>
            <p class="font-mono text-sm text-brand-white">${fmtJoules(a.chosen_cost.joules_per_op)}</p>
          </div>
          <div>
            <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1">s / op</p>
            <p class="font-mono text-sm text-brand-white">${fmtTime(a.chosen_cost.seconds_per_op)}</p>
          </div>
          <div>
            <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1">Acc loss</p>
            <p class="font-mono text-sm text-brand-white">${(a.chosen_cost.accuracy_loss * 100).toFixed(2)}%</p>
          </div>
        </div>
      </div>`;
  }).join('');

  root.innerHTML = headline + aggregate + invs;
}

$('dispatch-btn').addEventListener('click', dispatch);

// ────────────────────────────────────────────────────────────────────
// ONNX import
// ────────────────────────────────────────────────────────────────────
async function importOnnx(file) {
  const status = $('onnx-status');
  status.style.display = '';
  status.textContent = `READING ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)…`;
  try {
    const bytes = await file.arrayBuffer();
    status.textContent = `POSTING ${(bytes.byteLength / 1024 / 1024).toFixed(1)} MB to /api/import/onnx…`;
    const res = await fetch(`${API_BASE}/api/import/onnx`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/octet-stream' },
      body: bytes,
    });
    if (!res.ok) throw new Error(`HTTP ${res.status} — ${await res.text()}`);
    const report = await res.json();
    // Convert the workload's invocations back to form state.
    const fromReport = report.workload.invocations.map((iv) => {
      const p = PRIM_BY_ID[iv.primitive_id] || { kind: 'scalar' };
      const out = {
        primitive_id: iv.primitive_id,
        count: iv.count,
        label: iv.label,
        batch: iv.profile.batch || 1,
        dtype: iv.profile.dtype || 'f16',
        m: 1, k: 1, n: 1,
        variables: 1024, sweeps: 10000,
      };
      const dims = (iv.profile.shape && iv.profile.shape.dims) || [];
      if (p.kind === 'matmul' && dims.length >= 2 && iv.profile.reduce_dim) {
        out.m = dims[0];
        out.n = dims[1];
        out.k = iv.profile.reduce_dim;
      } else if (p.kind === 'sampling') {
        out.variables = iv.profile.variables || dims[0] || 1024;
        out.sweeps    = iv.profile.sweeps || 10000;
      } else {
        if (dims.length >= 2) { out.m = dims[0]; out.n = dims[1]; }
        if (iv.profile.reduce_dim) out.k = iv.profile.reduce_dim;
      }
      return out;
    });
    setInvocations(fromReport);
    const skipped = Object.entries(report.skipped_unmapped || {})
      .map(([k, v]) => `${k}×${v}`).join(', ');
    const skippedNote = skipped ? ` · unmapped: ${skipped}` : '';
    status.innerHTML = `<span class="text-brand-cyan">✓</span> ${report.model_name || file.name} · ${report.mapped_count}/${report.node_count} ops mapped${skippedNote}`;
    dispatch();
  } catch (e) {
    status.innerHTML = `<span style="color:#ef4444;">✗ Import failed:</span> ${e.message}`;
  }
}

$('onnx-file').addEventListener('change', (e) => {
  const file = e.target.files && e.target.files[0];
  if (file) importOnnx(file);
});

// ────────────────────────────────────────────────────────────────────
// Auto-load: populate with the transformer-layer preset and dispatch.
// ────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  $('preset').value = 'transformer-layer';
  setInvocations(preset('transformer-layer'));
  loadCatalogPresets();
  fetch(`${API_BASE}/health`).then(r => r.ok && dispatch()).catch(() => {});
});
</script>

</Layout>
