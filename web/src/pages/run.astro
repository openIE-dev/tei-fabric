---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Run" description="Execute a workload on the native substrate simulators and watch it happen — annealing, spiking, analog MVM, photonic meshes, CV quantum, adiabatic circuits, full-wave fields in 2D, 3D, and live on your own GPU. Pure Rust + WGSL.">

<section class="max-w-5xl mx-auto px-6 pt-20 pb-10">
  <p class="section-label mb-5">Execute &middot; ten live views</p>
  <h1 class="font-display text-5xl md:text-6xl font-bold text-brand-white leading-[1.05] tracking-tight mb-6">
    Watch the substrate <span class="text-brand-amber italic">compute</span>.
  </h1>
  <p class="text-brand-light text-lg md:text-xl max-w-3xl leading-relaxed">
    These are not cost estimates — they are the computations themselves, running in pure Rust and streamed event by event. Every column is validated against closed-form physics only: Onsager&rsquo;s critical temperature, the Clements decomposition, EPR correlations, the adiabatic ramp law. The event ledgers they return are what recalibrate the cost surface.
  </p>
</section>

<section class="max-w-7xl mx-auto px-6 pb-24">
  <!-- substrate picker -->
  <div id="picker" class="flex flex-wrap gap-2 mb-3"></div>
  <p id="cal-badge" class="font-mono text-[11px] tracking-wider mb-4" style="display:none;">
    <span class="text-brand-amber">●</span> <span class="text-brand-light">fabric is pricing with measured constants</span>
    <span id="cal-detail" class="text-brand-gray"></span>
    <button id="cal-clear" class="ml-2 text-brand-gray hover:text-brand-light underline decoration-dotted">revert to literature defaults</button>
  </p>

  <div class="grid lg:grid-cols-[380px_1fr] gap-6">
    <!-- controls -->
    <div class="glass-card p-6 self-start">
      <p class="section-label mb-1">Problem</p>
      <p id="sub-blurb" class="text-brand-gray text-[13px] leading-relaxed mb-4"></p>
      <div id="fields" class="grid grid-cols-2 gap-3 mb-5"></div>
      <button id="run-btn" class="primary w-full">RUN →</button>
      <div id="stats" class="mt-6 space-y-2 font-mono text-[12px] text-brand-light" style="display:none;"></div>
    </div>

    <!-- live view -->
    <div class="glass-card p-6">
      <div class="flex items-baseline justify-between mb-4">
        <p class="section-label" id="viz-title">live</p>
        <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider">pure rust &middot; sse</p>
      </div>
      <div class="relative aspect-[16/9]">
        <canvas id="chart" class="absolute inset-0 w-full h-full"></canvas>
      </div>
      <p id="status-line" class="font-mono text-[11px] text-brand-gray tracking-wider uppercase mt-3 text-center">idle — pick a column and run</p>
    </div>
  </div>
</section>

<script is:inline>
const API_BASE = (() => {
  const url = new URL(window.location.href);
  const o = url.searchParams.get('api');
  if (o) return o;
  if (url.hostname === 'localhost' || url.hostname === '127.0.0.1') return 'http://localhost:9651';
  return '';
})();
function $(id) { return document.getElementById(id); }

const AMBER = '#F59E0B', CYAN = 'rgba(14,165,233,0.45)', GREEN = '#34d399', GRAY = '#64748B';

// ── canvas helpers ────────────────────────────────────────────────────
const canvas = $('chart');
const ctx = canvas.getContext('2d');
function dpr() { return devicePixelRatio || 1; }
function resizeCanvas() {
  const r = canvas.getBoundingClientRect();
  canvas.width = r.width * dpr(); canvas.height = r.height * dpr();
}
new ResizeObserver(() => { resizeCanvas(); redraw(); }).observe(canvas);

function frame(xMin, xMax, yMin, yMax, xLabel) {
  const W = canvas.width, H = canvas.height, d = dpr();
  const padL = 70 * d, padB = 34 * d, padT = 12 * d, padR = 16 * d;
  ctx.clearRect(0, 0, W, H);
  if (yMax === yMin) { yMax += 1; yMin -= 1; }
  const yPad = (yMax - yMin) * 0.06; yMin -= yPad; yMax += yPad;
  ctx.strokeStyle = 'rgba(148,163,184,0.12)'; ctx.fillStyle = GRAY;
  ctx.font = `${11 * d}px "JetBrains Mono", monospace`; ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const v = yMin + (yMax - yMin) * i / 4, y = H - padB - (v - yMin) / (yMax - yMin) * (H - padT - padB);
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
    ctx.fillText(Math.abs(v) >= 1000 ? v.toFixed(0) : v.toPrecision(3), 6 * d, y + 4 * d);
  }
  if (xLabel) ctx.fillText(xLabel, W - padR - ctx.measureText(xLabel).width, H - 10 * d);
  return {
    px: x => padL + (x - xMin) / (xMax - xMin || 1) * (W - padL - padR),
    py: y => H - padB - (y - yMin) / (yMax - yMin) * (H - padT - padB),
  };
}
function polyline(pts, px, py, color, width) {
  ctx.strokeStyle = color; ctx.lineWidth = width * dpr(); ctx.beginPath();
  pts.forEach((p, i) => i ? ctx.lineTo(px(p[0]), py(p[1])) : ctx.moveTo(px(p[0]), py(p[1])));
  ctx.stroke();
}

// ── per-substrate state ───────────────────────────────────────────────
let view = { kind: 'idle' };   // what redraw() renders

function redraw() {
  const d = dpr();
  if (view.kind === 'series') {
    // generic line chart: view.series = [{pts, color, width}], optional hline
    const all = view.series.flatMap(s => s.pts);
    if (all.length < 2) { ctx.clearRect(0, 0, canvas.width, canvas.height); return; }
    const xs = all.map(p => p[0]), ys = all.map(p => p[1]).concat(view.hline != null ? [view.hline] : []);
    const f = frame(Math.min(...xs), Math.max(...xs), Math.min(...ys), Math.max(...ys), view.xLabel);
    if (view.hline != null) {
      ctx.strokeStyle = GREEN; ctx.setLineDash([6 * d, 5 * d]); ctx.beginPath();
      ctx.moveTo(f.px(Math.min(...xs)), f.py(view.hline)); ctx.lineTo(f.px(Math.max(...xs)), f.py(view.hline));
      ctx.stroke(); ctx.setLineDash([]);
      ctx.fillStyle = GREEN; ctx.fillText(view.hlineLabel || '', 80 * d, f.py(view.hline) - 6 * d);
    }
    view.series.forEach(s => polyline(s.pts, f.px, f.py, s.color, s.width));
  } else if (view.kind === 'raster') {
    const pts = view.pts; if (!pts.length) return;
    const f = frame(0, view.tMax, 0, view.nMax, 'time (s)');
    ctx.fillStyle = AMBER;
    const r = Math.max(1, 1.2 * d);
    for (const p of pts) { ctx.fillRect(f.px(p.t) - r / 2, f.py(p.neuron) - r / 2, r, r); }
  } else if (view.kind === 'hist') {
    const c = view.counts, n = c.length, lo = view.lo, hi = view.hi;
    const yMax = Math.max(...c, ...(view.overlay || [0]));
    const f = frame(lo, hi, 0, yMax, 'homodyne outcome x');
    const bw = (hi - lo) / n;
    ctx.fillStyle = 'rgba(245,158,11,0.55)';
    for (let i = 0; i < n; i++) {
      const x0 = f.px(lo + i * bw), x1 = f.px(lo + (i + 1) * bw), y = f.py(c[i]);
      ctx.fillRect(x0 + 1, y, Math.max(1, x1 - x0 - 2), f.py(0) - y);
    }
    if (view.overlay) polyline(view.overlay.map((v, i) => [lo + (i + 0.5) * bw, v]), f.px, f.py, '#0ea5e9', 2);
  } else if (view.kind === 'heatmap') {
    const { nx, ny, ez } = view;
    let amax = 1e-12; for (const v of ez) amax = Math.max(amax, Math.abs(v));
    const off = new OffscreenCanvas(nx, ny), octx = off.getContext('2d');
    const img = octx.createImageData(nx, ny);
    for (let j = 0; j < ny; j++) for (let i = 0; i < nx; i++) {
      const v = ez[j * nx + i] / amax, k = 4 * ((ny - 1 - j) * nx + i);
      // diverging: cyan (−) → near-black → amber (+)
      if (v >= 0) { img.data[k] = 245 * v + 8; img.data[k+1] = 158 * v + 10; img.data[k+2] = 11 * v + 16; }
      else { img.data[k] = 14 * -v + 8; img.data[k+1] = 165 * -v + 10; img.data[k+2] = 233 * -v + 16; }
      img.data[k+3] = 255;
    }
    octx.putImageData(img, 0, 0);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.imageSmoothingEnabled = true;
    const s = Math.min(canvas.width / nx, canvas.height / ny);
    ctx.drawImage(off, (canvas.width - nx * s) / 2, (canvas.height - ny * s) / 2, nx * s, ny * s);
  } else {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
  }
}

// ── substrate definitions ─────────────────────────────────────────────
// Each: blurb, viz title, fields, buildJob(v), onProgress(m), onResult(outputs, ledger)
const SUBSTRATES = {
  stochastic: {
    label: 'STOCHASTIC', blurb: 'Max-Cut annealed by chromatic block Gibbs on a thrml-class Ising sampler. Amber = best-so-far, cyan = instantaneous.',
    viz: 'cut value vs sweep · live',
    fields: [
      ['nodes', 'Nodes', 400], ['degree', 'Degree', 4],
      ['sweeps', 'Sweeps', 4000], ['seed', 'Seed', 42],
      ['beta0', 'β start', 0.1, 0.05], ['beta1', 'β end', 6, 0.5],
    ],
    buildJob: v => ({
      substrate: 'stochastic',
      problem: { kind: 'random_regular', n: v.nodes | 0, degree: v.degree | 0, seed: v.seed | 0 },
      schedule: { sweeps: v.sweeps | 0, beta0: v.beta0, beta1: v.beta1, kind: 'geometric' },
      seed: v.seed | 0,
    }),
    init() { this._cut = []; this._best = []; },
    onProgress(m) {
      if (m.cut == null) return;
      this._cut.push([m.sweep, m.cut]); this._best.push([m.sweep, m.best_cut]);
      view = { kind: 'series', xLabel: 'sweep', series: [
        { pts: this._cut, color: CYAN, width: 1.5 }, { pts: this._best, color: AMBER, width: 2.5 }] };
      redraw();
      status(`sweep ${m.sweep} · cut ${m.cut.toFixed(0)} · best ${m.best_cut.toFixed(0)} · β ${m.beta.toFixed(2)}`);
    },
    onResult(o, l) {
      return [['BEST CUT', fmt(o.best_cut), AMBER], ['EDGES', o.n_edges],
        ['SPIN UPDATES', fmt(l.spin_updates)], ['FLIPS', fmt(l.flips)],
        ['WALL', wall(l)], ['RATE', l.wall_seconds > 0 ? `${(l.spin_updates / l.wall_seconds / 1e6).toFixed(1)} M/s` : '—', '#0ea5e9']];
    },
  },

  spiking: {
    label: 'SPIKING', blurb: 'A recurrent LIF population under Poisson bombardment — Lava-class, exact exponential integrator. Each dot is one spike.',
    viz: 'spike raster · first 2000 spikes',
    fields: [
      ['n', 'Neurons', 200], ['prob', 'Conn p', 0.1, 0.01],
      ['weight', 'Syn w (mV)', 0.3, 0.05], ['rate', 'Poisson Hz', 8000],
      ['duration', 'Duration s', 0.5, 0.1], ['seed', 'Seed', 7],
    ],
    buildJob: v => ({
      substrate: 'spiking',
      layers: [{ name: 'exc', n: v.n | 0, tau: 0.02, v_rest: 0, v_reset: 0, v_th: 20,
        t_ref: 0.002, r: 1, i_ext: 0, poisson_rate: v.rate, poisson_weight: 0.5 }],
      connections: [{ pre: 0, post: 0, probability: v.prob, weight: v.weight, delay: 3 }],
      duration: v.duration, dt: 0.0001, seed: v.seed | 0,
    }),
    init() {},
    onProgress(m) { if (m.t != null) status(`t ${m.t.toFixed(3)} s · ${fmt(m.total_spikes)} spikes · ${m.rate_hz.toFixed(1)} Hz`); },
    onResult(o, l) {
      const pts = o.raster_sample || [];
      view = { kind: 'raster', pts, tMax: o.duration, nMax: o.n_neurons, };
      redraw();
      return [['MEAN RATE', `${o.mean_rate_hz.toFixed(1)} Hz`, AMBER], ['CV ISI', o.cv_isi?.toFixed(3)],
        ['NEURONS', o.n_neurons], ['SYNAPSES', fmt(o.n_synapses)],
        ['SPIKES', fmt(l.spikes)], ['SYN OPS', fmt(l.sops)], ['WALL', wall(l)]];
    },
  },

  crossbar: {
    label: 'CROSSBAR', blurb: 'Noisy analog matrix-vector multiply on a tiled memristive array — programming variability, read noise, DAC/ADC quantization. Live SNR as queries accumulate.',
    viz: 'output snr vs query · live',
    fields: [
      ['rows', 'Rows', 256], ['cols', 'Cols', 256],
      ['queries', 'Queries', 200], ['sigma', 'σ read', 0.01, 0.005],
      ['bits', 'ADC bits', 8], ['seed', 'Seed', 3],
    ],
    buildJob: v => ({
      substrate: 'crossbar', rows: v.rows | 0, cols: v.cols | 0, n_queries: v.queries | 0, seed: v.seed | 0,
      device: { sigma_read: v.sigma, adc: { bits: v.bits | 0, range: Math.sqrt(v.rows / 9) * 6 } },
    }),
    init() { this._snr = []; },
    onProgress(m) {
      if (m.snr_db == null) return;
      this._snr.push([m.query, m.snr_db]);
      view = { kind: 'series', xLabel: 'query', series: [{ pts: this._snr, color: AMBER, width: 2.5 }] };
      redraw();
      status(`query ${m.query} · snr ${m.snr_db.toFixed(1)} dB · rms ${m.rms_error.toExponential(2)}`);
    },
    onResult(o, l) {
      return [['SNR', `${o.snr_db.toFixed(1)} dB`, AMBER], ['RMS ERR', o.rms_error.toExponential(2)],
        ['ARRAY', `${o.rows}×${o.cols} on ${o.array_size}`], ['MACS', fmt(l.macs)],
        ['ADC SAMPLES', fmt(l.adc_samples)], ['WALL', wall(l)]];
    },
  },

  photonic: {
    label: 'PHOTONIC', blurb: 'A Haar-random unitary decomposed into a rectangular MZI mesh (Clements 2016 nulling), rebuilt, and driven with optical-power MVM queries. Live reconstruction fidelity.',
    viz: 'mvm error vs query · live',
    fields: [
      ['n', 'Modes N', 8], ['queries', 'Queries', 50],
      ['useed', 'Unitary seed', 11], ['seed', 'Seed', 5],
    ],
    buildJob: v => ({
      substrate: 'photonic', n: v.n | 0, unitary: { kind: 'random_haar', seed: v.useed | 0 },
      n_queries: v.queries | 0, seed: v.seed | 0,
    }),
    init() { this._err = []; },
    onProgress(m) {
      if (m.stage === 'decomposed') { status(`mesh: ${m.n_mzis} MZIs · recon err ${m.reconstruction_max_error.toExponential(1)}`); return; }
      if (m.rms_error != null) {
        this._err.push([m.queries_done, Math.log10(Math.max(m.rms_error, 1e-18))]);
        view = { kind: 'series', xLabel: 'query (log₁₀ rms err)', series: [{ pts: this._err, color: AMBER, width: 2.5 }] };
        redraw();
        status(`query ${m.queries_done} · mvm rms 1e${Math.log10(Math.max(m.rms_error, 1e-18)).toFixed(1)}`);
      }
    },
    onResult(o, l) {
      if (o.error) { status(`error: ${o.error}`); return []; }
      return [['RECON MAX ERR', o.reconstruction_max_error.toExponential(2), AMBER],
        ['MVM RMS', o.mvm_rms_error.toExponential(2)], ['MZIs', o.n_mzis], ['PHASES', o.n_phases],
        ['MACS', fmt(l.macs)], ['DETECTOR READS', fmt(l.adc_samples)], ['WALL', wall(l)]];
    },
  },

  gaussian: {
    label: 'GAUSSIAN', blurb: 'Two-mode squeezed vacuum — the EPR state — measured by homodyne, in the covariance-matrix formalism (ħ=2). Bars: 20k sampled shots. Cyan: the exact thermal marginal 𝒩(0, cosh 2r).',
    viz: 'homodyne histogram · x quadrature, mode 0',
    fields: [
      ['r', 'Squeeze r', 1.0, 0.1], ['shots', 'Shots', 20000],
      ['phi', 'Angle φ', 0, 0.1], ['seed', 'Seed', 4],
    ],
    buildJob: v => ({
      substrate: 'gaussian', n_modes: 2,
      circuit: [{ op: 'two_mode_squeeze', mode_a: 0, mode_b: 1, r: v.r }],
      homodyne: { mode: 0, phi: v.phi, shots: v.shots | 0 }, seed: v.seed | 0,
    }),
    init() {},
    onProgress(m) { if (m.shots_done != null) status(`${fmt(m.shots_done)} shots`); },
    onResult(o, l) {
      const h = o.homodyne;
      if (h?.histogram) {
        const { counts, lo, hi } = h.histogram, n = counts.length, bw = (hi - lo) / n;
        const sig2 = h.marginal_variance, norm = h.shots * bw / Math.sqrt(2 * Math.PI * sig2);
        const overlay = Array.from({ length: n }, (_, i) => {
          const x = lo + (i + 0.5) * bw; return norm * Math.exp(-x * x / (2 * sig2));
        });
        view = { kind: 'hist', counts, lo, hi, overlay };
        redraw();
      }
      const m0 = o.modes?.[0];
      return [['⟨n⟩ MODE 0', m0?.mean_photons.toFixed(4), AMBER],
        ['VAR (exact)', h?.marginal_variance.toFixed(4)], ['VAR (sampled)', h?.sample_variance.toFixed(4)],
        ['PHYSICALITY', o.physicality_margin != null ? o.physicality_margin.toExponential(1) : (o.symplectic_min_nu != null ? (o.symplectic_min_nu - 1).toExponential(1) : '—')],
        ['SHOTS', fmt(h?.shots)], ['WALL', wall(l)]];
    },
  },

  adiabatic: {
    label: 'ADIABATIC', blurb: 'A ramp-charged cell swept across T/RC, plotted as overhead above the Landauer floor. The green dashed line is the cost dialect’s assumed constant (10³×) — the sweep measures where on the curve that assumption actually lives.',
    viz: 'overhead above landauer vs T/RC · log–log · live',
    fields: [
      ['r', 'R (Ω)', 1000], ['c', 'C (fF)', 1, 0.5],
      ['v', 'V rail', 0.7, 0.1], ['points', 'Points', 13],
    ],
    buildJob(v) {
      this._floor = 4 * 2.85e-21;
      const n = Math.max(3, v.points | 0);
      const ratios = Array.from({ length: n }, (_, i) => Math.pow(10, 3 * i / (n - 1)));
      return { substrate: 'adiabatic', cell: { kind: 'ramp_charge', r_ohm: v.r, c_f: v.c * 1e-15, v: v.v }, ratios };
    },
    init() { this._pts = []; },
    onProgress(m) {
      if (m.ratio == null) return;
      this._pts.push([Math.log10(m.ratio), Math.log10(m.e_diss_j / this._floor)]);
      this._pts.sort((a, b) => a[0] - b[0]);
      view = { kind: 'series', xLabel: 'log₁₀ T/RC · dashed = dialect’s assumed 10³',
        hline: 3, hlineLabel: 'REVERSIBLE_OVERHEAD_L0 = 10³',
        series: [{ pts: this._pts, color: AMBER, width: 2.5 }] };
      redraw();
      status(`T/RC ${m.ratio.toPrecision(3)} · overhead 10^${Math.log10(m.e_diss_j / this._floor).toFixed(2)}`);
    },
    onResult(o, l) {
      if (o.error) { status(`error: ${o.error}`); return []; }
      return [['LOG–LOG SLOPE', o.fitted_loglog_slope?.toFixed(3), AMBER],
        ['ABRUPT ½CV²', `${o.abrupt_limit_j?.toExponential(2)} J`],
        ['RC', `${o.params?.rc_s?.toExponential(2)} s`], ['WALL', wall(l)]];
    },
  },

  circuit: {
    label: 'CIRCUIT', blurb: 'A capacitor charged through a resistor by a linear ramp — the adiabatic-computing energy argument, run live. Slow the ramp and watch dissipation fall as (RC/T)·CV².',
    viz: 'node voltages vs time · live',
    fields: [
      ['ratio', 'T / RC', 100], ['r', 'R (Ω)', 1000],
      ['c', 'C (nF)', 100], ['v', 'V final', 1.0, 0.1],
    ],
    buildJob(v) {
      const rc = v.r * v.c * 1e-9, T = v.ratio * rc;
      this._pred = { adia: (rc / T) * (v.c * 1e-9) * v.v * v.v, abrupt: 0.5 * v.c * 1e-9 * v.v * v.v };
      return {
        substrate: 'circuit',
        netlist: { elements: [
          { kind: 'voltage_source', name: 'vclk', p: 1, n: 0, wave: { shape: 'ramp', v: v.v, t_ramp: T } },
          { kind: 'resistor', name: 'r1', p: 1, n: 2, r: v.r },
          { kind: 'capacitor', name: 'c1', p: 2, n: 0, c: v.c * 1e-9, ic: 0 },
        ]},
        t_stop: 2 * T, dt: Math.min(rc / 50, T / 2000),
      };
    },
    init() {},
    onProgress(m) { if (m.fraction != null || m.t != null) status(`simulating…`); },
    onResult(o, l) {
      if (o.error) { status(`error: ${o.error}`); return []; }
      const series = (o.nodes || []).map((vs, k) => ({
        pts: vs.map((y, i) => [o.t[i], y]), color: k === 0 ? CYAN : AMBER, width: k === 0 ? 1.5 : 2.5 }));
      view = { kind: 'series', xLabel: 'time (s) · cyan=clock amber=cap', series };
      redraw();
      const er = o.element_energy_j?.r1;
      return [['E DISSIPATED', `${er?.toExponential(3)} J`, AMBER],
        ['(RC/T)CV² PRED', `${this._pred.adia.toExponential(3)} J`, GREEN],
        ['ABRUPT ½CV²', `${this._pred.abrupt.toExponential(3)} J`],
        ['SAVINGS', `${(this._pred.abrupt / er).toFixed(1)}×`, '#0ea5e9'],
        ['TELLEGEN MAX', `${o.tellegen_max_w?.toExponential(1)} W`], ['STEPS', fmt(o.steps)], ['WALL', wall(l)]];
    },
  },

  field: {
    label: 'FIELD', blurb: 'A Gaussian pulse radiating across a 2D Yee FDTD grid into CPML absorbers, with an ε_r=4 dielectric slab on the right. The heatmap is the final Ez field — amber positive, cyan negative.',
    viz: 'Ez field snapshot · final step',
    fields: [
      ['nx', 'Grid nx', 200], ['ny', 'Grid ny', 200],
      ['steps', 'Steps', 360], ['slab', 'Slab ε_r', 4, 0.5],
    ],
    buildJob: v => ({
      substrate: 'field', nx: v.nx | 0, ny: v.ny | 0, steps: v.steps | 0,
      eps: { kind: 'slab', eps_r: v.slab, i0: Math.round(v.nx * 0.7), i1: Math.round(v.nx * 0.85) },
      source: { shape: { shape: 'point', i: Math.round(v.nx * 0.35), j: Math.round(v.ny / 2) },
        time: { type: 'gaussian', t0: 40, tau: 12 } },
      probe: [Math.round(v.nx * 0.9), Math.round(v.ny / 2)],
      snapshot: true,
    }),
    init() {},
    onProgress(m) { if (m.step != null) status(`step ${m.step} · Ez(probe) ${m.ez_probe?.toExponential(2) ?? ''}`); },
    onResult(o, l) {
      if (o.snapshot?.ez) { view = { kind: 'heatmap', nx: o.snapshot.nx, ny: o.snapshot.ny, ez: o.snapshot.ez }; redraw(); }
      return [['GRID', `${o.snapshot?.nx}×${o.snapshot?.ny}`], ['STEPS', fmt(o.steps)],
        ['FIELD UPDATES', fmt(l.macs), AMBER], ['MONITOR READS', fmt(l.adc_samples)], ['WALL', wall(l)]];
    },
  },

  fieldgpu: {
    label: 'FIELD GPU', blurb: 'The same 2D FDTD — but the Yee updates run as WGSL compute shaders on YOUR GPU, in this tab, live. The kernels are validated natively against the f64 CPU core to ~10⁻⁶; the buffer packing comes from the server so the contract is single-sourced. After the run, the same job executes on the CPU core and the probe traces are compared.',
    viz: 'Ez field · live on your GPU · webgpu',
    fields: [
      ['n', 'Grid n²', 320], ['steps', 'Steps', 1600],
      ['slab', 'Slab ε_r', 4, 0.5], ['chunk', 'Steps/frame', 6],
    ],
    init() {},
    onProgress() {}, onResult() { return []; },
    async customRun(v) {
      if (!navigator.gpu) { status('webgpu not available in this browser'); return; }
      const n = v.n | 0, steps = v.steps | 0;
      const job = {
        nx: n, ny: n, steps,
        eps: { kind: 'slab', eps_r: v.slab, i0: Math.round(n * 0.7), i1: Math.round(n * 0.85) },
        source: { shape: { shape: 'point', i: Math.round(n * 0.35), j: Math.round(n / 2) },
          time: { type: 'gaussian', t0: 40.0, tau: 12.0 } },
        probe: [Math.round(n * 0.9), Math.round(n / 2)],
      };
      status('packing buffers on server…');
      const [shaders, pack] = await Promise.all([
        fetch(`${API_BASE}/api/field-gpu-shaders`).then(r => r.json()),
        fetch(`${API_BASE}/api/field-gpu-pack`, { method: 'POST',
          headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(job) }).then(r => {
            if (!r.ok) throw new Error('pack failed'); return r.json(); }),
      ]);
      const adapter = await navigator.gpu.requestAdapter();
      if (!adapter) { status('no gpu adapter'); return; }
      const dev = await adapter.requestDevice();
      const P = pack.params, nx = P.nx, ny = P.ny;

      // Buffers — contract documented in tei-sim-field/src/gpu/mod.rs.
      const f32buf = (arr, usage) => {
        const b = dev.createBuffer({ size: Math.max(16, arr.length * 4), usage });
        dev.queue.writeBuffer(b, 0, new Float32Array(arr)); return b;
      };
      const zeroed = len => dev.createBuffer({ size: Math.max(16, len * 4), usage: GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_SRC });
      const ST = GPUBufferUsage.STORAGE | GPUBufferUsage.COPY_DST;
      const paramsBuf = dev.createBuffer({ size: 48, usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST });
      {
        const dvw = new DataView(new ArrayBuffer(48));
        [P.nx, P.ny, P.npml, P.src_kind, P.src_i, P.src_j0, P.src_j1, P.probe_idx]
          .forEach((x, i) => dvw.setUint32(i * 4, x, true));
        dvw.setFloat32(32, P.dt, true);
        dev.queue.writeBuffer(paramsBuf, 0, dvw.buffer);
      }
      const ezBuf = zeroed(nx * ny), hxBuf = zeroed(nx * (ny - 1)), hyBuf = zeroed((nx - 1) * ny);
      const ceBuf = f32buf(pack.ce, ST), coeffBuf = f32buf(pack.coeff, ST);
      const psiE = zeroed(2 * nx * ny), psiH = zeroed(nx * (ny - 1) + (nx - 1) * ny);
      const traceBuf = zeroed(steps);
      const stepBuf = dev.createBuffer({ size: 256 * steps, usage: GPUBufferUsage.UNIFORM | GPUBufferUsage.COPY_DST });
      {
        const slots = new ArrayBuffer(256 * steps), dvw = new DataView(slots);
        for (let s = 0; s < steps; s++) { dvw.setFloat32(256 * s, pack.amps[s], true); dvw.setUint32(256 * s + 4, s, true); }
        dev.queue.writeBuffer(stepBuf, 0, slots);
      }

      // One explicit layout superset shared by all four pipelines.
      const rw = { type: 'storage' }, ro = { type: 'read-only-storage' };
      const bgl0 = dev.createBindGroupLayout({ entries: [
        { binding: 0, visibility: GPUShaderStage.COMPUTE, buffer: { type: 'uniform' } },
        ...[1, 2, 3, 5, 6, 8].map(b => ({ binding: b, visibility: GPUShaderStage.COMPUTE, buffer: rw })),
        ...[4, 7].map(b => ({ binding: b, visibility: GPUShaderStage.COMPUTE, buffer: ro })),
      ]});
      const bgl1 = dev.createBindGroupLayout({ entries: [
        { binding: 0, visibility: GPUShaderStage.COMPUTE, buffer: { type: 'uniform', hasDynamicOffset: true, minBindingSize: 16 } }]});
      const layout = dev.createPipelineLayout({ bindGroupLayouts: [bgl0, bgl1] });
      const pipe = (code, entry) => dev.createComputePipeline({ layout,
        compute: { module: dev.createShaderModule({ code }), entryPoint: entry } });
      const pH = pipe(shaders.update_h, 'update_h'), pE = pipe(shaders.update_e, 'update_e');
      const pI = pipe(shaders.inject, 'inject'), pP = pipe(shaders.inject, 'record_probe');
      const bg0 = dev.createBindGroup({ layout: bgl0, entries: [
        { binding: 0, resource: { buffer: paramsBuf } }, { binding: 1, resource: { buffer: ezBuf } },
        { binding: 2, resource: { buffer: hxBuf } }, { binding: 3, resource: { buffer: hyBuf } },
        { binding: 4, resource: { buffer: ceBuf } }, { binding: 5, resource: { buffer: psiE } },
        { binding: 6, resource: { buffer: psiH } }, { binding: 7, resource: { buffer: coeffBuf } },
        { binding: 8, resource: { buffer: traceBuf } }]});
      const bg1 = dev.createBindGroup({ layout: bgl1, entries: [
        { binding: 0, resource: { buffer: stepBuf, size: 16 } }]});

      const staging = dev.createBuffer({ size: nx * ny * 4, usage: GPUBufferUsage.COPY_DST | GPUBufferUsage.MAP_READ });
      const wgx = Math.ceil(nx / 16), wgy = Math.ceil(ny / 16);
      const srcWg = Math.ceil((P.src_j1 - P.src_j0 + 1) / 64);
      const chunk = Math.max(1, v.chunk | 0);
      const t0 = performance.now();
      let step = 0;
      while (step < steps) {
        const k = Math.min(chunk, steps - step);
        const enc = dev.createCommandEncoder();
        const pass = enc.beginComputePass();
        pass.setBindGroup(0, bg0);
        for (let s = 0; s < k; s++) {
          pass.setBindGroup(1, bg1, [256 * (step + s)]);
          pass.setPipeline(pH); pass.dispatchWorkgroups(wgx, wgy);
          pass.setPipeline(pE); pass.dispatchWorkgroups(wgx, wgy);
          if (pack.has_source) { pass.setPipeline(pI); pass.dispatchWorkgroups(srcWg); }
          pass.setPipeline(pP); pass.dispatchWorkgroups(1);
        }
        pass.end();
        enc.copyBufferToBuffer(ezBuf, 0, staging, 0, nx * ny * 4);
        dev.queue.submit([enc.finish()]);
        await staging.mapAsync(GPUMapMode.READ);
        const ez = new Float32Array(staging.getMappedRange().slice(0));
        staging.unmap();
        step += k;
        view = { kind: 'heatmap', nx, ny, ez };
        redraw();
        const mc = (step * nx * ny) / ((performance.now() - t0) / 1000) / 1e6;
        status(`step ${step}/${steps} · ${mc.toFixed(0)} MCells/s on your GPU`);
        await new Promise(r => requestAnimationFrame(r));
      }
      const gpuSecs = (performance.now() - t0) / 1000;

      // Read the probe trace, then cross-check against the CPU core.
      status('cross-checking against the CPU core…');
      const traceStage = dev.createBuffer({ size: steps * 4, usage: GPUBufferUsage.COPY_DST | GPUBufferUsage.MAP_READ });
      { const enc = dev.createCommandEncoder(); enc.copyBufferToBuffer(traceBuf, 0, traceStage, 0, steps * 4);
        dev.queue.submit([enc.finish()]); }
      await traceStage.mapAsync(GPUMapMode.READ);
      const gpuTrace = new Float32Array(traceStage.getMappedRange().slice(0));
      traceStage.unmap();

      let rows = [['GRID', `${nx}×${ny}`], ['STEPS', fmt(steps)],
        ['GPU THROUGHPUT', `${((steps * nx * ny) / gpuSecs / 1e6).toFixed(0)} MCells/s`, AMBER]];
      try {
        const res = await fetch(`${API_BASE}/api/execute`, { method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ substrate: 'field', ...job, frequencies: [] }) });
        const reader = res.body.getReader(), dec = new TextDecoder();
        let buf = '', cpu = null;
        while (true) {
          const { value, done } = await reader.read(); if (done) break;
          buf += dec.decode(value, { stream: true });
          let i; while ((i = buf.indexOf('\n\n')) >= 0) {
            const block = buf.slice(0, i); buf = buf.slice(i + 2);
            if (block.includes('event: result')) {
              const data = block.split('\n').filter(l => l.startsWith('data:')).map(l => l.slice(5).trim()).join('');
              cpu = JSON.parse(data);
            }
          }
        }
        const pr = cpu.outputs.probe, stride = pr.stride || 1;
        let peak = 0, dmax = 0;
        for (let k = 0; k < pr.trace.length; k++) {
          const g = gpuTrace[k * stride]; if (g === undefined) break;
          peak = Math.max(peak, Math.abs(pr.trace[k]));
          dmax = Math.max(dmax, Math.abs(g - pr.trace[k]));
        }
        rows.push(['CPU WALL (server)', `${(cpu.ledger?.wall_seconds ?? 0).toFixed(2)} s`]);
        rows.push(['GPU WALL (here)', `${gpuSecs.toFixed(2)} s`, AMBER]);
        rows.push(['GPU vs CPU max |Δ|/peak', (dmax / peak).toExponential(1), GREEN]);
      } catch { rows.push(['CPU CROSS-CHECK', 'unavailable']); }
      const el = $('stats'); el.innerHTML = '';
      for (const [k2, v2, color] of rows) {
        const div = document.createElement('div'); div.className = 'flex justify-between';
        div.innerHTML = `<span class="text-brand-gray">${k2}</span><span${color ? ` style="color:${color}" class="font-bold"` : ''}>${v2}</span>`;
        el.appendChild(div);
      }
      el.style.display = '';
      status('done — field computed on your GPU, verified against the CPU core');
    },
  },

  field3: {
    label: 'FIELD 3D', blurb: 'A dipole pulse in a full 3D Yee grid with CPML on all six faces and an ε_r=4 box — six field components, rayon-parallel slabs, bit-identical at any thread count. The heatmap is a |E| slice through the source plane.',
    viz: '|E| slice · z midplane · final step',
    fields: [
      ['n', 'Grid n³', 64], ['steps', 'Steps', 420],
      ['eps', 'Box ε_r', 4, 0.5],
    ],
    buildJob: v => {
      const n = v.n | 0, c = Math.round(n / 2);
      return {
        substrate: 'field3', nx: n, ny: n, nz: n, steps: v.steps | 0,
        eps: { kind: 'box', eps_r: v.eps, i0: Math.round(n * 0.6), i1: Math.round(n * 0.85),
          j0: Math.round(n * 0.3), j1: Math.round(n * 0.7), k0: Math.round(n * 0.3), k1: Math.round(n * 0.7) },
        source: { i: Math.round(n * 0.3), j: c, k: c, axis: 'z',
          time: { type: 'gaussian', t0: 30.0, tau: 9.0 } },
        probes: [{ i: Math.round(n * 0.75), j: c, k: c, component: 'ez' }],
        snapshot: { axis: 'z', index: c, field: 'e_mag' },
      };
    },
    init() {},
    onProgress(m) { if (m.step != null) status(`step ${m.step} · Ez(probe) ${m.ez_probe?.toExponential(2) ?? ''}`); },
    onResult(o, l) {
      const s = o.snapshot;
      if (s?.data) { view = { kind: 'heatmap', nx: s.n0, ny: s.n1, ez: s.data }; redraw(); }
      return [['GRID', `${s?.n0}×${s?.n1} slice of ${$('f-n').value}³`], ['STEPS', fmt(o.steps)],
        ['FIELD UPDATES', fmt(l.macs), AMBER], ['WALL', wall(l)]];
    },
  },
};

// ── generic plumbing ──────────────────────────────────────────────────
let active = 'stochastic';
function fmt(x) { return x == null ? '—' : Number(x).toLocaleString(); }
function wall(l) { const w = l.wall_seconds ?? 0; return w < 1 ? `${(w * 1000).toFixed(0)} ms` : `${w.toFixed(2)} s`; }
function status(s) { $('status-line').textContent = s; }

function renderPicker() {
  $('picker').innerHTML = '';
  for (const key of Object.keys(SUBSTRATES)) {
    const b = document.createElement('button');
    b.textContent = SUBSTRATES[key].label;
    b.className = 'font-mono text-[11px] tracking-wider px-4 py-2 rounded-lg border transition-colors ' +
      (key === active
        ? 'border-brand-amber text-brand-amber bg-brand-amber/10'
        : 'border-white/10 text-brand-gray hover:text-brand-light hover:border-white/25');
    b.onclick = () => { active = key; renderPicker(); renderFields(); view = { kind: 'idle' }; redraw(); $('stats').style.display = 'none'; status('ready'); };
    $('picker').appendChild(b);
  }
}

function renderFields() {
  const s = SUBSTRATES[active];
  $('sub-blurb').textContent = s.blurb;
  $('viz-title').textContent = s.viz;
  $('fields').innerHTML = '';
  for (const [id, label, value, step] of s.fields) {
    const wrap = document.createElement('div');
    wrap.innerHTML = `<label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">${label}</label>
      <input id="f-${id}" type="number" value="${value}" ${step ? `step="${step}"` : ''} />`;
    $('fields').appendChild(wrap);
  }
}

function values() {
  const v = {};
  for (const [id] of SUBSTRATES[active].fields) v[id] = parseFloat($(`f-${id}`).value);
  return v;
}

async function run() {
  const s = SUBSTRATES[active];
  const btn = $('run-btn');
  btn.disabled = true; btn.textContent = 'RUNNING…';
  $('stats').style.display = 'none';
  view = { kind: 'idle' }; redraw();
  s.init();
  if (s.customRun) {
    try { await s.customRun(values()); }
    catch (e) { status(`failed: ${e.message}`); }
    finally { btn.disabled = false; btn.textContent = 'RUN →'; }
    return;
  }
  status('connecting…');
  try {
    const res = await fetch(`${API_BASE}/api/execute`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'text/event-stream' },
      body: JSON.stringify(s.buildJob(values())),
    });
    if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);
    const reader = res.body.getReader(), dec = new TextDecoder();
    let buf = '';
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += dec.decode(value, { stream: true });
      let i;
      while ((i = buf.indexOf('\n\n')) >= 0) { handleBlock(buf.slice(0, i).trim(), s); buf = buf.slice(i + 2); }
    }
  } catch (e) {
    status(`failed: ${e.message} — is tei-serve running?`);
  } finally {
    btn.disabled = false; btn.textContent = 'RUN →';
  }
}

function handleBlock(block, s) {
  let evt = 'message'; const data = [];
  for (const line of block.split('\n')) {
    if (line.startsWith('event:')) evt = line.slice(6).trim();
    else if (line.startsWith('data:')) data.push(line.slice(5).trim());
  }
  if (!data.length) return;
  let payload; try { payload = JSON.parse(data.join('')); } catch { return; }
  if (evt === 'progress') s.onProgress(payload.metrics || {});
  else if (evt === 'result') {
    const rows = s.onResult(payload.outputs || {}, payload.ledger || {}) || [];
    const cal = payload.calibration;
    if (cal && cal.estimated_j != null) {
      rows.push(['— CALIBRATION —', '']);
      rows.push(['EST (DIALECT)', `${cal.estimated_j.toExponential(2)} J`]);
      rows.push(['MEASURED (LEDGER)', `${cal.measured_j.toExponential(2)} J`, AMBER]);
      if (cal.measured_over_estimated != null)
        rows.push(['MEASURED / EST', cal.measured_over_estimated.toFixed(3), GREEN]);
      const d = cal.details || {};
      if (d.measured_activity != null)
        rows.push(['ACTIVITY ASSUMED→MEAS', `${d.assumed_activity} → ${d.measured_activity.toFixed(3)}`]);
      if (d.crossover_t_over_rc != null)
        rows.push(['10³ CROSSOVER AT T/RC', d.crossover_t_over_rc.toFixed(1), GREEN]);
      if (cal.substrate_params_patch) repriceDispatch(cal.substrate_params_patch, d.patch_t_over_rc);
    }
    const el = $('stats'); el.innerHTML = '';
    for (const [k, v, color] of rows) {
      const div = document.createElement('div');
      div.className = 'flex justify-between';
      div.innerHTML = `<span class="text-brand-gray">${k}</span><span${color ? ` style="color:${color}" class="font-bold"` : ''}>${v ?? '—'}</span>`;
      el.appendChild(div);
    }
    el.style.display = '';
    status('done');
  }
}

// Close the loop: re-price a reversible-heavy dispatch plan with the
// measured overhead and show it beside the assumed-constant plan.
async function repriceDispatch(patch, atRatio) {
  const workload = {
    goal: 'adiabatic re-price', constraints: { cycles_per_second: 1.0, power_budget_w: 100.0, accuracy_floor: 0.9 },
    invocations: [
      { primitive_id: 79, count: 10000000, label: 'dct', profile: { shape: { dims: [64] }, batch: 1 } },
      { primitive_id: 80, count: 10000000, label: 'hilbert', profile: { shape: { dims: [64] }, batch: 1 } },
    ],
  };
  const call = body => fetch(`${API_BASE}/api/dispatch`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
  }).then(r => r.json());
  try {
    const [before, after] = await Promise.all([
      call(workload), call({ ...workload, substrate_params: patch })]);
    const el = $('stats');
    const add = (k, v, color) => {
      const div = document.createElement('div');
      div.className = 'flex justify-between';
      div.innerHTML = `<span class="text-brand-gray">${k}</span><span${color ? ` style="color:${color}" class="font-bold"` : ''}>${v}</span>`;
      el.appendChild(div);
    };
    add('— RE-PRICED DISPATCH —', '');
    add('PLAN (ASSUMED 10³)', `${before.total_joules.toExponential(2)} J`);
    add(`PLAN (MEASURED @ T/RC ${atRatio?.toFixed(0) ?? ''})`, `${after.total_joules.toExponential(2)} J`, AMBER);
    add('PLAN CHANGE', `${(before.total_joules / after.total_joules).toFixed(1)}× cheaper`, GREEN);
    const btn = document.createElement('button');
    btn.textContent = 'APPLY TO FABRIC → every /api/dispatch prices with this';
    btn.className = 'w-full mt-2 font-mono text-[11px] tracking-wider px-3 py-2 rounded-lg border border-brand-amber/40 text-brand-amber hover:bg-brand-amber/10 transition-colors';
    btn.onclick = async () => {
      btn.disabled = true; btn.textContent = 'SAVING…';
      const r = await fetch(`${API_BASE}/api/calibration`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(patch),
      });
      btn.textContent = r.ok ? 'SAVED — fabric now prices with the measured constant' : 'SAVE FAILED';
      refreshCalBadge();
    };
    el.appendChild(btn);
  } catch { /* dispatch unavailable — leave stats as-is */ }
}

async function refreshCalBadge() {
  try {
    const c = await fetch(`${API_BASE}/api/calibration`).then(r => r.json());
    $('cal-badge').style.display = c.calibrated ? '' : 'none';
    if (c.calibrated) {
      const ov = c.substrate_params?.reversible?.overhead_l0;
      $('cal-detail').textContent = ov != null ? ` · reversible overhead_l0 = ${Number(ov).toPrecision(4)} (literature: 1000)` : '';
    }
  } catch { /* server unreachable */ }
}
$('cal-clear').addEventListener('click', async () => {
  await fetch(`${API_BASE}/api/calibration`, { method: 'DELETE' });
  refreshCalBadge();
});

$('run-btn').addEventListener('click', run);
window.addEventListener('DOMContentLoaded', () => {
  renderPicker(); renderFields(); resizeCanvas(); refreshCalBadge();
  fetch(`${API_BASE}/health`).then(r => r.ok && run()).catch(() => {});
});
</script>

</Layout>
