      '<th class="pr-4 pb-2">J/op</th><th class="pr-4 pb-2">n_ops</th><th class="pr-4 pb-2">provenance</th><th class="pb-2">when</th></tr></thead><tbody>' +
      rows.map(x => `<tr class="border-t border-white/5">
