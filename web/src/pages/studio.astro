---
import Layout from '../layouts/Layout.astro';
---
<Layout title="TEI Studio" description="The turnkey face of thermodynamic compute on current-generation hardware. Connect a board, see its joules live — install nothing, ever.">

<section class="max-w-[1500px] mx-auto px-6 pt-10 pb-24">
  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div>
      <h1 class="font-display text-2xl font-bold text-brand-white tracking-tight">TEI <span class="text-brand-amber italic">Studio</span></h1>
      <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider mt-1">the browser workbench for compute — program · build · flash · measure in joules · deploy · built on teiOS</p>
    </div>
    <p class="font-mono text-[10px] text-brand-gray uppercase tracking-wider">cmd-K commands · install nothing, ever</p>
  </div>

  <div class="flex gap-5">
    <nav id="rail" class="flex flex-col gap-1 shrink-0 w-32">
      <button data-ws="code"    class="ws-btn">CODE</button>
      <button data-ws="build"   class="ws-btn">BUILD</button>
      <button data-ws="flash"   class="ws-btn">FLASH</button>
      <button data-ws="console" class="ws-btn">CONSOLE</button>
      <button data-ws="data"    class="ws-btn ws-soon">DATA</button>
      <button data-ws="ai"      class="ws-btn">AI</button>
      <button data-ws="fleet"   class="ws-btn ws-soon">FLEET</button>
      <button data-ws="hub"     class="ws-btn">HUB</button>
    </nav>

    <div class="flex-1 min-w-0">
      <div id="ws-console" class="ws">
        <div class="grid lg:grid-cols-[380px_1fr] gap-6">
    <!-- connect panel -->
    <div class="glass-card p-6 self-start">
      <p class="section-label mb-3">Console</p>
      <p id="serial-support" class="text-brand-gray text-[13px] leading-relaxed mb-4"></p>
      <button id="btn-connect" class="primary w-full">CONNECT A BOARD →</button>
      <div class="grid grid-cols-2 gap-3 mt-4">
        <div>
          <label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">Baud</label>
          <input id="baud" type="number" value="115200" />
        </div>
        <div>
          <label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">Demo</label>
          <button id="btn-demo" class="w-full font-mono text-[11px] tracking-wider px-3 py-2 rounded-lg border border-white/15 text-brand-light hover:border-brand-amber/50 hover:text-brand-amber transition-colors">SIMULATE</button>
        </div>
      </div>
      <div id="stats" class="mt-6 space-y-2 font-mono text-[12px] text-brand-light" style="display:none;"></div>
    </div>

    <!-- live ledger -->
    <div class="glass-card p-6">
      <div class="flex items-baseline justify-between mb-2">
        <p class="section-label">live ledger</p>
        <p id="conn-state" class="font-mono text-[10px] text-brand-gray uppercase tracking-wider">disconnected</p>
      </div>
      <div id="prov-bar" class="hidden mb-3 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[11px] bg-black/30 rounded-lg px-3 py-2">
        <span><span class="text-brand-gray">board</span> <span id="pv-board" class="text-brand-white">—</span></span>
        <span><span class="text-brand-gray">provenance</span> <span id="pv-src" class="text-brand-amber">—</span></span>
        <span><span class="text-brand-gray">odometer</span> <span id="pv-odo" class="text-brand-light">0 J</span>
          <button id="pv-odo-reset" class="ml-1 text-brand-gray hover:text-brand-light underline decoration-dotted">reset</button></span>
        <span id="pv-issues-wrap" class="hidden"><span class="text-brand-gray">issues</span> <span id="pv-issues"></span></span>
      </div>
      <div class="relative aspect-[16/8]">
        <canvas id="chart" class="absolute inset-0 w-full h-full"></canvas>
      </div>
      <div class="relative h-9 mt-1" title="event lane — click an event to select around it">
        <canvas id="lane" class="absolute inset-0 w-full h-full cursor-pointer"></canvas>
      </div>
      <div id="selstrip" class="mt-3 hidden">
        <div class="flex items-center justify-between mb-2">
          <p class="font-mono text-[10px] text-brand-amber uppercase tracking-wider">selection</p>
          <div class="flex gap-2">
            <button id="btn-clear-sel" class="font-mono text-[10px] text-brand-gray hover:text-brand-light underline decoration-dotted">clear</button>
            <button id="btn-publish-sel" class="font-mono text-[10px] tracking-wider px-3 py-1 rounded border border-brand-amber/40 text-brand-amber hover:bg-brand-amber/10 transition-colors">PUBLISH SELECTION → fabric</button>
          </div>
        </div>
        <div id="selstats" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2 font-mono text-[11px]"></div>
      </div>
      <div id="log" class="mt-3 h-40 overflow-y-auto font-mono text-[11px] leading-relaxed text-brand-gray bg-black/30 rounded-lg p-3"></div>
    </div>
  </div>

      </div>

      <div id="ws-code" class="ws hidden">
        <div class="grid lg:grid-cols-[1fr_320px] gap-5">
          <div class="glass-card p-4">
            <div class="flex items-center justify-between mb-3">
              <p class="section-label">app.rs — your program on teiOS</p>
              <div class="flex gap-2 items-center">
                <span id="code-state" class="font-mono text-[10px] text-brand-gray uppercase"></span>
                <button id="btn-code-reset" class="font-mono text-[10px] text-brand-gray hover:text-brand-light underline decoration-dotted">reset to template</button>
              </div>
            </div>
            <div id="code-editor" class="rounded-lg overflow-hidden border border-white/10 text-[13px]"></div>
          </div>
          <div class="glass-card p-5 self-start">
            <p class="section-label mb-3">the teiOS app surface</p>
            <p class="text-brand-gray text-[12px] leading-relaxed mb-3">
              An app is a function teiOS schedules. Everything it does is
              ledgered; everything it runs is dispatched to the lowest-joule
              substrate the board's cost table knows.</p>
            <pre class="font-mono text-[11px] text-brand-light bg-black/30 rounded-lg p-3 leading-relaxed overflow-x-auto">run(FFT, buf)      -> Ledger
run_on(PIO, ...)   -> Ledger
cheapest(FFT)      -> Substrate
ledger().joules    -> Option&lt;f64&gt;
publish(report)    -> fabric</pre>
            <p class="text-brand-gray text-[11px] leading-relaxed mt-3">
              Edits build through the forge (BUILD tab). The unmodified
              template maps to the shipped image — flashable right now.</p>
          </div>
        </div>
      </div>

      <div id="ws-build" class="ws hidden">
        <div class="glass-card p-6 max-w-2xl">
          <p class="section-label mb-3">forge build</p>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
              <label class="block font-mono text-[10px] text-brand-gray uppercase tracking-wider mb-1.5">Target</label>
              <select id="build-target" class="w-full bg-black/40 rounded-lg px-3 py-2 font-mono text-[12px] text-brand-white border border-white/10">
                <option value="feather-rp2040">Adafruit Feather RP2040</option>
                <option value="pico">Raspberry Pi Pico</option>
                <option value="pico2">Raspberry Pi Pico 2</option>
                <option value="portenta-h7" disabled>Portenta H7 (image building — E1b)</option>
              </select>
            </div>
            <div class="flex items-end"><button id="btn-build" class="primary w-full">BUILD →</button></div>
          </div>
          <div id="build-out" class="font-mono text-[11px] text-brand-gray bg-black/30 rounded-lg p-3 min-h-[80px] whitespace-pre-wrap">the forge resolves your CODE tab source against the target.
unmodified template -> the shipped, tested image (instant).
modified source -> the forge build service (sandboxed builders; the
next backend milestone — honest status, not a dead button).</div>
        </div>
      </div>

      <div id="ws-flash" class="ws hidden">
        <p class="section-label mb-5">Boards &middot; the install paths</p>
  <div id="boards" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
  <p class="text-brand-gray text-[12px] mt-6 leading-relaxed max-w-3xl">
    Install tiers: <span class="text-brand-light">W1</span> = direct browser
    flash (WebSerial/WebUSB) · <span class="text-brand-light">W2</span> =
    file-write, works in every browser (UF2 drag-drop; Pi-class boards are
    flat files on a FAT card, because teiOS is not Linux) ·
    <span class="text-brand-light">W3</span> = the teiProbe bridge — one
    drag-drop UF2 turns any $4 Pico into a browser-driven programmer for
    everything else. The full matrix lives in the
    <a href="https://github.com/openIE-dev/tei-fabric/blob/main/docs/EMBEDDED-TARGETS.md" class="text-brand-amber hover:underline">target catalog</a>.
  </p>

      </div>

      <div id="ws-data" class="ws hidden"><div class="glass-card p-6 max-w-xl"><p class="section-label mb-2">data</p><p class="text-brand-gray text-[13px]">Board data capture &amp; analysis lands after the console's dataset export. The joule traces in CONSOLE are the first dataset.</p></div></div>
      <div id="ws-fleet" class="ws hidden"><div class="glass-card p-6 max-w-xl"><p class="section-label mb-2">fleet</p><p class="text-brand-gray text-[13px]">Multi-board operations + OTA land after Improv WiFi provisioning — boards will POST ledgers home without a browser tether.</p></div></div>

      <div id="ws-ai" class="ws hidden">
        <div class="glass-card p-6 max-w-2xl">
          <p class="section-label mb-3">ai — in front of the grammar, never around it</p>
          <p class="text-brand-light text-[13px] leading-relaxed mb-3">Today: the cmd-K palette parses the deterministic Tier-0 grammar (try <span class="font-mono text-brand-amber">help</span>). Landing in order: Tier-0.5 zero-download translation (Chrome built-in Prompt API), Tier-1 in-browser LFM2.5-350M, dispatch-decision explanation cards on the console's anomaly chips, calibration-plan generation, model dev + deploy per board with measured J/inference.</p>
          <button id="btn-open-ck" class="font-mono text-[11px] tracking-wider px-4 py-2 rounded-lg border border-brand-amber/40 text-brand-amber hover:bg-brand-amber/10 transition-colors">OPEN cmd-K</button>
        </div>
      </div>

      <div id="ws-hub" class="ws hidden">
        <div class="glass-card p-6">
          <div class="flex items-center justify-between mb-4">
            <p class="section-label">hub — the community calibration store</p>
            <button id="btn-hub-refresh" class="font-mono text-[10px] text-brand-gray hover:text-brand-light underline decoration-dotted">refresh</button>
          </div>
          <div id="hub-table" class="font-mono text-[12px] text-brand-light overflow-x-auto">loading…</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ws-btn { font-size: 11px; letter-spacing: 0.08em; text-align: left; font-family: 'JetBrains Mono', monospace;
    padding: 9px 14px; border-radius: 10px; color: rgb(100 116 139); border: 1px solid transparent; transition: all .15s; }
  .ws-btn:hover { color: rgb(226 232 240); }
  .ws-btn.active { color: #F59E0B; background: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.25); }
  .ws-soon { opacity: 0.45; }
</style>

<!-- command-K palette: Tier-0 deterministic grammar (STUDIO-DESIGN §5).
     Fuzzy in → exact parsed command rendered → Enter executes. Tiers
     0.5/1 (NL translation) slot in front of the same grammar later. -->
<div id="ck-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-start justify-center pt-[18vh]">
  <div class="w-full max-w-xl glass-card p-4">
    <input id="ck-input" type="text" placeholder="type a command — try: help"
      class="w-full bg-black/40 rounded-lg px-4 py-3 font-mono text-[14px] text-brand-white outline-none border border-white/10 focus:border-brand-amber/50" autocomplete="off" spellcheck="false" />
    <div id="ck-parsed" class="mt-3 font-mono text-[12px] min-h-[20px]"></div>
    <p class="mt-2 font-mono text-[10px] text-brand-gray uppercase tracking-wider">⌘K toggle · Enter run · Esc close · grammar is deterministic — AI tiers translate INTO it, never around it</p>
  </div>
</div>

<script is:inline>
const API_BASE = (() => {
  const url = new URL(window.location.href);
  const o = url.searchParams.get('api');
  if (o) return o;
  if (url.hostname === 'localhost' || url.hostname === '127.0.0.1') return 'http://localhost:9651';
  return '';  // prod: same-origin /api/* via Caddy (fabric + studio hosts both proxy)
})();
function $(id) { return document.getElementById(id); }
const AMBER = '#F59E0B', CYAN = 'rgba(14,165,233,0.55)', GREEN = '#34d399', GRAY = '#64748B';

// ── board catalog (curated from docs/EMBEDDED-TARGETS.md) ─────────────
const BOARDS = [
  { name: 'Portenta H7 / H7 Lite', tier: 'W1', via: 'WebUSB DFU — browser-flashable today (double-tap reset)', sub: 'STM32H747 dual-core: M7@480 vs M4@240 — heterogeneous-core dispatch on one die', status: 'E1b flagship · on the bench' },
  { name: 'Adafruit Feather RP2040', tier: 'W2', via: 'UF2 drag-drop — every browser, even Safari', sub: 'CPU vs DMA-sniffer CRC race, dispatched live — the E1a firmware', status: 'FLASHABLE NOW · on the bench', uf2: '/teios/teios-feather-rp2040.uf2' },
  { name: 'Raspberry Pi Pico / Pico 2', tier: 'W2', via: 'UF2 drag-drop', sub: 'Pico = RP2040 build; Pico 2 = RP2350 build (hardware-unverified: none on the bench)', status: 'FLASHABLE NOW', uf2: '/teios/teios-pico.uf2', uf2b: { label: 'Pico 2', url: '/teios/teios-pico2.uf2' } },
  { name: 'Particle Tachyon', tier: 'Tier 0', via: 'tachyon-os (in-house bare-metal Rust OS)', sub: 'QCM6490: big.LITTLE + Hexagon NPU + 5G; PMIC ADCs = candidate self-telemetry', status: 'teiOS-on-Snapdragon · on the bench' },
  { name: 'OpenMV AE3', tier: 'Tier 0', via: 'OpenMV / Alif SETOOLS', sub: 'Alif E3: dual M55 + dual Ethos-U55 — the open-Vela NPU + vision bundle', status: 'NPU column · on the bench' },
  { name: 'Nicla Voice', tier: 'W3', via: 'Arduino / BLE DFU', sub: 'Syntiant NDP120: always-on audio inference at sub-mW while the host sleeps', status: 'the µW dispatch story · on the bench' },
  { name: 'Nano Matter (preview)', tier: 'W3', via: 'Arduino core (onboard DAP)', sub: 'EFR32MG24: MVP AI accelerator + Matter/BLE radio', status: 'MVP substrate · on the bench' },
  { name: 'Portenta C33', tier: 'W1', via: 'DFU / Arduino', sub: 'Renesas RA6M5 (M33) + ESP32-C3 radio for calibration upload', status: 'on the bench' },
  { name: 'Coral Dev Board Mini', tier: 'teid', via: 'SD / fastboot (Mendel Linux)', sub: 'Edge TPU ~2 TOPS/W — J/inference rows via the delegate ledger', status: 'teid path · on the bench' },
  { name: 'Raspberry Pi Zero 2 W', tier: 'W2', via: 'files on FAT — the not-Linux unlock', sub: '4×A53 bare metal; the SD-image flagship', status: 'E3 · on the bench' },
];
const boardsEl = $('boards');
for (const b of BOARDS) {
  const d = document.createElement('div');
  d.className = 'glass-card p-5';
  d.innerHTML = `<div class="flex items-baseline justify-between mb-2">
      <span class="text-brand-white font-semibold">${b.name}</span>
      <span class="font-mono text-[10px] text-brand-amber">${b.tier}</span></div>
    <p class="text-brand-gray text-[12px] leading-relaxed mb-2">${b.sub}</p>
    <p class="font-mono text-[10px] text-brand-light tracking-wider">${b.via}</p>
    <p class="font-mono text-[10px] text-brand-gray mt-2 uppercase">${b.status}</p>
    ${b.uf2 ? `<div class="mt-3 flex gap-2">
        <a href="${b.uf2}" download class="font-mono text-[10px] tracking-wider px-3 py-1.5 rounded border border-brand-amber/50 text-brand-amber hover:bg-brand-amber/10 transition-colors">⬇ FLASH teiOS (UF2)</a>
        ${b.uf2b ? `<a href="${b.uf2b.url}" download class="font-mono text-[10px] tracking-wider px-3 py-1.5 rounded border border-white/15 text-brand-light hover:border-brand-amber/50 transition-colors">⬇ ${b.uf2b.label}</a>` : ''}
      </div>
      <p class="text-brand-gray text-[10px] mt-2">hold BOOTSEL → plug in → drag onto RPI-RP2 → CONNECT above</p>` : ''}`;
  boardsEl.appendChild(d);
}

// ── chart: joules per run, by substrate ───────────────────────────────
const canvas = $('chart'), ctx = canvas.getContext('2d');
function dpr() { return devicePixelRatio || 1; }
function resize() { const r = canvas.getBoundingClientRect(); canvas.width = r.width * dpr(); canvas.height = r.height * dpr(); laneResize(); draw(); drawLane(); }
new ResizeObserver(resize).observe(canvas);
const series = new Map(); // substrate -> [{t, j, msg}]
const events = [];        // {t, kind: 'ledger'|'dispatch'|'check', substrate?, ok?, chosen?}
const lane = $('lane'), lctx = lane.getContext('2d');
function laneResize() { const r = lane.getBoundingClientRect(); lane.width = r.width * dpr(); lane.height = r.height * dpr(); }
function subColor(name) {
  const keys = [...series.keys()];
  const i = keys.indexOf(name);
  return colors[(i < 0 ? keys.length : i) % colors.length];
}
function drawLane() {
  if (!lane.width) laneResize();
  const W = lane.width, H = lane.height, d = dpr();
  lctx.clearRect(0, 0, W, H);
  if (!lastX || !events.length) return;
  const { xMin, xMax, padL, padR } = lastX;
  const px = t => padL + (t - xMin) / (xMax - xMin || 1) * (W - padL - padR);
  lctx.strokeStyle = 'rgba(148,163,184,0.15)';
  lctx.beginPath(); lctx.moveTo(padL, H/2); lctx.lineTo(W - padR, H/2); lctx.stroke();
  for (const e of events) {
    if (e.t < xMin || e.t > xMax) continue;
    const x = px(e.t);
    if (e.kind === 'ledger') {
      lctx.fillStyle = subColor(e.substrate);
      lctx.beginPath(); lctx.arc(x, H * 0.30, 2.2*d, 0, 7); lctx.fill();
    } else if (e.kind === 'dispatch') {
      lctx.fillStyle = AMBER;
      lctx.save(); lctx.translate(x, H * 0.62); lctx.rotate(Math.PI/4);
      lctx.fillRect(-2.4*d, -2.4*d, 4.8*d, 4.8*d); lctx.restore();
    } else if (e.kind === 'check' && !e.ok) {
      lctx.strokeStyle = '#f87171'; lctx.lineWidth = 1.6*d;
      lctx.beginPath();
      lctx.moveTo(x - 3*d, H * 0.78 - 3*d); lctx.lineTo(x + 3*d, H * 0.78 + 3*d);
      lctx.moveTo(x + 3*d, H * 0.78 - 3*d); lctx.lineTo(x - 3*d, H * 0.78 + 3*d);
      lctx.stroke();
    }
  }
  if (sel) {
    const x0 = px(Math.max(Math.min(sel.t0, sel.t1), xMin)), x1 = px(Math.min(Math.max(sel.t0, sel.t1), xMax));
    lctx.fillStyle = 'rgba(245,158,11,0.10)';
    lctx.fillRect(x0, 0, Math.max(1, x1 - x0), H);
  }
}
lane.addEventListener('click', ev => {
  if (!lastX || !events.length) return;
  const r = lane.getBoundingClientRect();
  const xpx = (ev.clientX - r.left) * dpr();
  const { xMin, xMax, padL, padR } = lastX;
  const t = xMin + Math.min(1, Math.max(0, (xpx - padL) / (lane.width - padL - padR))) * (xMax - xMin);
  let best = null, bd = 1e9;
  for (const e of events) { const d2 = Math.abs(e.t - t); if (d2 < bd) { bd = d2; best = e; } }
  if (!best) return;
  sel = { t0: best.t - 1.0, t1: best.t + 1.0 };
  draw(); drawLane(); renderSelection();
  logLine(`selected ±1s around ${best.kind}${best.substrate ? ' (' + best.substrate + ')' : ''} @ ${best.t.toFixed(1)}s`, '#0ea5e9');
});
let sel = null;           // {t0, t1} in chart time
let lastX = null;         // px<->t mapping cache from draw()
const colors = [AMBER, '#0ea5e9', GREEN, '#f472b6', '#a78bfa'];
let t0 = null;
function draw() {
  const W = canvas.width, H = canvas.height, d = dpr();
  ctx.clearRect(0, 0, W, H);
  const all = [...series.values()].flat();
  if (all.length < 2) {
    ctx.fillStyle = GRAY; ctx.font = `${12*d}px "JetBrains Mono", monospace`;
    ctx.fillText('waiting for ledger lines…', 20*d, H/2);
    return;
  }
  const padL = 86*d, padB = 30*d, padT = 14*d, padR = 14*d;
  const xs = all.map(p => p.t), ys = all.map(p => p.j);
  let xMin = Math.min(...xs), xMax = Math.max(...xs), yMin = Math.min(...ys), yMax = Math.max(...ys);
  if (yMax === yMin) { yMax *= 1.5; yMin *= 0.5; }
  const px = x => padL + (x - xMin) / (xMax - xMin || 1) * (W - padL - padR);
  const py = y => H - padB - (y - yMin) / (yMax - yMin) * (H - padT - padB);
  lastX = { xMin, xMax, padL, padR, W };
  ctx.strokeStyle = 'rgba(148,163,184,0.12)'; ctx.fillStyle = GRAY; ctx.font = `${10*d}px "JetBrains Mono", monospace`;
  for (let i = 0; i <= 3; i++) {
    const v = yMin + (yMax - yMin) * i / 3, y = py(v);
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
    ctx.fillText(v.toExponential(1) + ' J', 6*d, y + 3*d);
  }
  if (sel && lastX) {
    const x0 = px(Math.max(sel.t0, xMin)), x1 = px(Math.min(sel.t1, xMax));
    ctx.fillStyle = 'rgba(245,158,11,0.10)';
    ctx.fillRect(x0, padT, Math.max(1, x1 - x0), H - padT - padB);
    ctx.strokeStyle = AMBER; ctx.lineWidth = 1.2*d;
    ctx.beginPath(); ctx.moveTo(x0, padT); ctx.lineTo(x0, H - padB); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x1, padT); ctx.lineTo(x1, H - padB); ctx.stroke();
  }
  let ci = 0;
  for (const [name, pts] of series) {
    const c = colors[ci++ % colors.length];
    ctx.strokeStyle = c; ctx.lineWidth = 2*d; ctx.beginPath();
    pts.forEach((p, i) => i ? ctx.lineTo(px(p.t), py(p.j)) : ctx.moveTo(px(p.t), py(p.j)));
    ctx.stroke();
    ctx.fillStyle = c; ctx.fillText(name, padL + 8*d + (ci-1)*150*d, padT + 10*d);
  }
}

// ── ledger stream handling (the teiOS JSON-lines protocol) ────────────
const counts = { ledger: 0, dispatch: 0, check_ok: 0, check_fail: 0 };
let lastDispatch = null, boardId = null;
let odometerJ = 0, lastSrc = null;
const issues = new Map(); // key -> {count, label, sev}
function issue(key, label, sev) {
  const e = issues.get(key) || { count: 0, label, sev };
  e.count++; issues.set(key, e);
  renderProv();
}
function renderProv() {
  const bar = $('prov-bar');
  if (!boardId && !odometerJ) return;
  bar.classList.remove('hidden');
  $('pv-board').textContent = boardId || '—';
  $('pv-src').textContent = lastSrc || '—';
  $('pv-src').style.color = lastSrc === 'measured' ? GREEN : (lastSrc === 'cycles_proxy' ? '#0ea5e9' : AMBER);
  $('pv-odo').textContent = odometerJ < 1e-3 ? odometerJ.toExponential(2) + ' J' : odometerJ.toFixed(3) + ' J';
  const wrap = $('pv-issues-wrap'), el = $('pv-issues');
  if (!issues.size) { wrap.classList.add('hidden'); return; }
  wrap.classList.remove('hidden');
  el.innerHTML = [...issues.values()].map(i =>
    `<span class="px-1.5 py-0.5 rounded mr-1" style="background:${i.sev === 'err' ? 'rgba(248,113,113,0.15)' : 'rgba(245,158,11,0.12)'};color:${i.sev === 'err' ? '#f87171' : AMBER}">${i.label} ×${i.count}</span>`).join('');
}
function logLine(s, cls) {
  const el = $('log'); const div = document.createElement('div');
  if (cls) div.style.color = cls;
  div.textContent = s; el.appendChild(div);
  while (el.childElementCount > 200) el.removeChild(el.firstChild);
  el.scrollTop = el.scrollHeight;
}
function handleLine(line) {
  line = line.trim(); if (!line) return;
  let m; try { m = JSON.parse(line); } catch { logLine(line); return; }
  if (m.type === 'ledger') {
    counts.ledger++;
    boardId = m.board_id || boardId;
    const j = m.ledger && m.ledger.joules;
    const t = (Date.now() - (t0 ??= Date.now())) / 1000;
    if (j != null) {
      odometerJ += j;
      lastSrc = m.ledger.joules_source || lastSrc;
      if (!series.has(m.substrate)) series.set(m.substrate, []);
      const pts = series.get(m.substrate); pts.push({ t, j, msg: m });
      if (pts.length > 300) pts.shift();
      events.push({ t, kind: 'ledger', substrate: m.substrate });
      if (events.length > 900) events.shift();
      draw(); drawLane(); renderProv();
    }
    logLine(`ledger ${m.substrate} · ${m.ledger?.cycles ?? '—'} cyc · ${j != null ? j.toExponential(2) + ' J (' + (m.ledger.joules_source || '?') + ')' : 'unpriced'}`);
  } else if (m.type === 'dispatch') {
    counts.dispatch++;
    if (lastDispatch && lastDispatch.chosen !== m.chosen)
      issue('flip:' + lastDispatch.chosen + '>' + m.chosen, `dispatch flip ${lastDispatch.chosen}→${m.chosen}`, 'warn');
    lastDispatch = m;
    events.push({ t: (Date.now() - (t0 ??= Date.now())) / 1000, kind: 'dispatch', chosen: m.chosen });
    logLine(`dispatch → ${m.chosen} @ ${Number(m.j_per_op).toExponential(2)} J/op`, AMBER);
    drawLane();
  } else if (m.type === 'check') {
    m.ok ? counts.check_ok++ : counts.check_fail++;
    if (!m.ok) {
      logLine('CHECK FAILED', '#f87171'); issue('check-fail', 'check failed', 'err');
      events.push({ t: (Date.now() - (t0 ??= Date.now())) / 1000, kind: 'check', ok: false });
      drawLane();
    }
  } else { logLine(line); }
  renderStats();
}
function renderStats() {
  const el = $('stats'); el.style.display = '';
  const rows = [
    ['BOARD', boardId ?? '—'],
    ['LEDGERS', counts.ledger],
    ['DISPATCHES', counts.dispatch, AMBER],
    ['CHECKS', `${counts.check_ok} ok${counts.check_fail ? ' · ' + counts.check_fail + ' FAIL' : ''}`, counts.check_fail ? '#f87171' : GREEN],
  ];
  if (lastDispatch) rows.push(['CHOSEN SUBSTRATE', lastDispatch.chosen, AMBER]);
  el.innerHTML = '';
  for (const [k, v, color] of rows) {
    const div = document.createElement('div');
    div.className = 'flex justify-between';
    div.innerHTML = `<span class="text-brand-gray">${k}</span><span${color ? ` style="color:${color}" class="font-bold"` : ''}>${v}</span>`;
    el.appendChild(div);
  }
}

// ── WebSerial ──────────────────────────────────────────────────────────
const hasSerial = !!navigator.serial;
$('serial-support').textContent = hasSerial
  ? 'WebSerial available. Plug in a board running teiOS (or anything speaking the JSON-lines ledger protocol) and connect.'
  : 'This browser has no WebSerial (Chromium-only for now) — the SIMULATE demo still works, and UF2/file installs never need it.';
let port = null, reader = null;
async function connect() {
  if (!hasSerial) return;
  try {
    port = await navigator.serial.requestPort();
    await port.open({ baudRate: parseInt($('baud').value) || 115200 });
    $('conn-state').textContent = 'connected';
    $('btn-connect').textContent = 'DISCONNECT';
    const dec = new TextDecoderStream();
    port.readable.pipeTo(dec.writable);
    reader = dec.readable.getReader();
    let buf = '';
    for (;;) {
      const { value, done } = await reader.read();
      if (done) break;
      buf += value;
      let i; while ((i = buf.indexOf('\n')) >= 0) { handleLine(buf.slice(0, i)); buf = buf.slice(i + 1); }
    }
  } catch (e) {
    logLine('serial: ' + (e.message || e), '#f87171');
  } finally {
    $('conn-state').textContent = 'disconnected';
    $('btn-connect').textContent = 'CONNECT A BOARD →';
    try { reader?.releaseLock(); await port?.close(); } catch {}
    port = null;
  }
}
$('btn-connect').addEventListener('click', () => {
  if (port) { reader?.cancel(); } else connect();
});

// ── simulator: emits protocol-faithful lines so the console is testable
//    (and demo-able) with zero hardware ─────────────────────────────────
let demoTimer = null;
$('btn-demo').addEventListener('click', () => {
  if (demoTimer) { clearInterval(demoTimer); demoTimer = null; $('btn-demo').textContent = 'SIMULATE'; return; }
  $('btn-demo').textContent = 'STOP';
  $('conn-state').textContent = 'simulated board';
  let n = 0;
  demoTimer = setInterval(() => {
    n++;
    const cpuJ = 96e-6 * (1 + 0.05 * Math.sin(n / 5));
    const dmaJ = 41e-6 * (1 + 0.04 * Math.cos(n / 7));
    handleLine(JSON.stringify({ type: 'ledger', board_id: 'pico2-sim', substrate: 'cpu@150mhz', primitive_id: 36, n_ops: 1,
      ledger: { cycles: 14400000 + (n % 7) * 1000, dma_transfers: 0, adc_samples: 0, accel_invocations: 0, sleep_us: 0, active_us: 96000, joules: cpuJ, joules_source: 'table' } }));
    handleLine(JSON.stringify({ type: 'ledger', board_id: 'pico2-sim', substrate: 'dma-sniffer', primitive_id: 36, n_ops: 1,
      ledger: { cycles: 0, dma_transfers: 16384, adc_samples: 0, accel_invocations: 1, sleep_us: 90000, active_us: 6000, joules: dmaJ, joules_source: 'table' } }));
    // every 7th tick the noise makes the CPU win — exercising the
    // dispatch-flip detector the way a real noisy board would
    const flip = n % 7 === 0;
    handleLine(JSON.stringify({ type: 'dispatch', primitive_id: 36,
      chosen: flip ? 'cpu@150mhz' : 'dma-sniffer',
      j_per_op: flip ? cpuJ : dmaJ,
      alternatives: [{ substrate: flip ? 'dma-sniffer' : 'cpu@150mhz', j_per_op: flip ? dmaJ : cpuJ }] }));
    handleLine(JSON.stringify({ type: 'check', ok: true }));
  }, 1000);
});

// ── selection: drag on the chart → region → joules → publish ──────────
function evT(ev) {
  if (!lastX) return null;
  const r = canvas.getBoundingClientRect();
  const xpx = (ev.clientX - r.left) * dpr();
  const { xMin, xMax, padL, padR, W } = lastX;
  const frac = (xpx - padL) / (W - padL - padR);
  return xMin + Math.min(1, Math.max(0, frac)) * (xMax - xMin);
}
let dragging = false;
canvas.addEventListener('pointerdown', ev => {
  const t = evT(ev); if (t == null) return;
  dragging = true; sel = { t0: t, t1: t };
  canvas.setPointerCapture(ev.pointerId);
});
canvas.addEventListener('pointermove', ev => {
  if (!dragging || !sel) return;
  const t = evT(ev); if (t == null) return;
  sel.t1 = t; draw(); drawLane(); renderSelection();
});
canvas.addEventListener('pointerup', () => {
  dragging = false;
  if (sel && Math.abs(sel.t1 - sel.t0) < 0.05) { sel = null; draw(); }
  renderSelection();
});

function selRows() {
  if (!sel) return [];
  const [a, b] = [Math.min(sel.t0, sel.t1), Math.max(sel.t0, sel.t1)];
  const rows = [];
  for (const [name, pts] of series) {
    const inSel = pts.filter(p => p.t >= a && p.t <= b);
    if (!inSel.length) continue;
    const sum = inSel.reduce((s, p) => s + p.j, 0);
    const nOps = inSel.reduce((s, p) => s + (p.msg.n_ops || 1), 0);
    rows.push({
      substrate: name, runs: inSel.length, nOps,
      joules: sum, jPerOp: sum / nOps, dt: b - a,
      sample: inSel[inSel.length - 1].msg,
    });
  }
  return rows;
}
function renderSelection() {
  const strip = $('selstrip'), el = $('selstats');
  const rows = selRows();
  if (!rows.length) { strip.classList.add('hidden'); return; }
  strip.classList.remove('hidden');
  el.innerHTML = '';
  for (const r of rows) {
    const d = document.createElement('div');
    d.className = 'bg-black/30 rounded-lg p-2';
    d.innerHTML = `<div class="text-brand-amber">${r.substrate}</div>
      <div class="text-brand-light">${r.joules.toExponential(2)} J · ${r.runs} runs</div>
      <div class="text-brand-gray">${r.jPerOp.toExponential(2)} J/op · Δt ${r.dt.toFixed(1)}s · ${r.sample.ledger?.joules_source || '?'}</div>`;
    el.appendChild(d);
  }
}
$('btn-clear-sel').addEventListener('click', () => { sel = null; draw(); renderSelection(); });
$('pv-odo-reset').addEventListener('click', () => { odometerJ = 0; renderProv(); logLine('odometer reset'); });
$('btn-publish-sel').addEventListener('click', async () => {
  const rows = selRows(); if (!rows.length) return;
  const btn = $('btn-publish-sel');
  btn.disabled = true; btn.textContent = 'PUBLISHING…';
  let ok = 0, fail = 0;
  for (const r of rows) {
    const report = {
      board_id: r.sample.board_id || boardId || 'unknown',
      substrate: r.substrate,
      primitive_id: r.sample.primitive_id ?? 0,
      n_ops: r.nOps,
      ledger: r.sample.ledger || {},
      j_per_op: r.jPerOp,
    };
    try {
      const resp = await fetch(`${API_BASE}/api/calibration/reports`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(report),
      });
      resp.ok ? ok++ : fail++;
      if (!resp.ok) logLine('publish HTTP ' + resp.status + ': ' + (await resp.text()).slice(0, 120), '#f87171');
    } catch (e) { fail++; logLine('publish error: ' + (e && e.message || e), '#f87171'); }
  }
  btn.textContent = fail ? `PUBLISHED ${ok}, FAILED ${fail}` : `PUBLISHED ${ok} ROW${ok === 1 ? '' : 'S'} ✓`;
  setTimeout(() => { btn.disabled = false; btn.textContent = 'PUBLISH SELECTION → fabric'; }, 3000);
  logLine(`published ${ok} calibration row(s) to the fabric` + (fail ? ` (${fail} failed)` : ''), ok ? GREEN : '#f87171');
});

// ── command-K: the Tier-0 grammar ─────────────────────────────────────
// Each command: regex → {cmd, args, describe, run}. The PARSE is the
// contract; the palette shows the exact parsed command before running.
const GRAMMAR = [
  { re: /^help$/i, cmd: 'help', describe: () => 'list commands',
    run: () => logLine('commands: connect · disconnect · simulate · stop · clear · baud <n> · select last <n>s · publish · flash <board> · boards · help', AMBER) },
  { re: /^connect$/i, cmd: 'connect', describe: () => 'open the WebSerial port picker',
    run: () => $('btn-connect').click() },
  { re: /^disconnect$/i, cmd: 'disconnect', describe: () => 'close the serial connection',
    run: () => { if (port) $('btn-connect').click(); else logLine('not connected'); } },
  { re: /^sim(ulate)?$/i, cmd: 'simulate', describe: () => 'start the protocol-faithful simulated board',
    run: () => { if (!demoTimer) $('btn-demo').click(); } },
  { re: /^stop$/i, cmd: 'stop', describe: () => 'stop the simulated board',
    run: () => { if (demoTimer) $('btn-demo').click(); } },
  { re: /^clear$/i, cmd: 'clear', describe: () => 'clear chart series, selection, and log',
    run: () => { series.clear(); events.length = 0; sel = null; t0 = null; odometerJ = 0; issues.clear(); $('log').innerHTML = ''; draw(); drawLane(); renderSelection(); renderProv(); } },
  { re: /^baud\s+(\d{3,7})$/i, cmd: 'baud', describe: m => `set serial baud to ${m[1]}`,
    run: m => { $('baud').value = m[1]; logLine(`baud set to ${m[1]} (takes effect on next connect)`); } },
  { re: /^select\s+last\s+(\d+)\s*s(econds)?$/i, cmd: 'select', describe: m => `select the last ${m[1]} seconds of the trace`,
    run: m => {
      const all = [...series.values()].flat();
      if (!all.length) { logLine('nothing to select'); return; }
      const tMax = Math.max(...all.map(p => p.t));
      sel = { t0: Math.max(0, tMax - parseInt(m[1])), t1: tMax };
      draw(); renderSelection();
    } },
  { re: /^publish$/i, cmd: 'publish', describe: () => 'publish the current selection to the fabric',
    run: () => { if (sel) $('btn-publish-sel').click(); else logLine('no selection — drag on the chart or: select last 10s'); } },
  { re: /^flash\s+(\S+)$/i, cmd: 'flash', describe: m => `download the teiOS UF2 for "${m[1]}" (staged — the browser download IS the consent step)`,
    run: m => {
      const q = m[1].toLowerCase();
      const hit = BOARDS.find(b => b.uf2 && b.name.toLowerCase().includes(q)) ||
                  (q.includes('pico2') || q.includes('pico 2') ? BOARDS.find(b => b.uf2b) : null);
      if (!hit) { logLine(`no flashable image for "${m[1]}" — try: flash feather · flash pico`, '#f87171'); return; }
      const url = (q.includes('pico2') && hit.uf2b) ? hit.uf2b.url : hit.uf2;
      const a = document.createElement('a'); a.href = url; a.download = ''; a.click();
      logLine(`downloading ${url.split('/').pop()} — hold BOOTSEL, drag onto RPI-RP2, then: connect`, AMBER);
    } },
  { re: /^boards$/i, cmd: 'boards', describe: () => 'scroll to the board catalog',
    run: () => $('boards').scrollIntoView({ behavior: 'smooth' }) },
];

function ckParse(text) {
  const t = text.trim();
  if (!t) return null;
  for (const g of GRAMMAR) {
    const m = t.match(g.re);
    if (m) return { g, m };
  }
  return { unknown: t };
}
const ckOverlay = $('ck-overlay'), ckInput = $('ck-input'), ckParsed = $('ck-parsed');
function ckShow() { ckOverlay.classList.remove('hidden'); ckOverlay.classList.add('flex'); ckInput.value = ''; ckRender(); setTimeout(() => ckInput.focus(), 30); }
function ckHide() { ckOverlay.classList.add('hidden'); ckOverlay.classList.remove('flex'); }
function ckRender() {
  const p = ckParse(ckInput.value);
  if (!p) { ckParsed.innerHTML = '<span class="text-brand-gray">…</span>'; return; }
  if (p.unknown) {
    ckParsed.innerHTML = `<span class="text-brand-gray">unrecognized — Tier-0 grammar only (AI translation lands next). try </span><span class="text-brand-amber">help</span>`;
    return;
  }
  ckParsed.innerHTML = `<span class="text-brand-amber">→ ${p.g.cmd}</span> <span class="text-brand-light">· ${p.g.describe(p.m)}</span> <span class="text-brand-gray">· Enter to run</span>`;
}
ckInput.addEventListener('input', ckRender);
ckInput.addEventListener('keydown', e => {
  if (e.key === 'Escape') { ckHide(); }
  else if (e.key === 'Enter') {
    const p = ckParse(ckInput.value);
    if (p && p.g) { ckHide(); logLine(`⌘ ${p.g.cmd}`, '#0ea5e9'); p.g.run(p.m); }
    else ckRender();
  }
});
ckOverlay.addEventListener('pointerdown', e => { if (e.target === ckOverlay) ckHide(); });
window.addEventListener('keydown', e => {
  if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); ckOverlay.classList.contains('hidden') ? ckShow() : ckHide(); }
});

// ── workspaces: the rail IS the IDE ──────────────────────────────────
const WS = ['code','build','flash','console','data','ai','fleet','hub'];
function wsShow(name) {
  if (!WS.includes(name)) name = 'console';
  for (const w of WS) {
    document.getElementById('ws-' + w)?.classList.toggle('hidden', w !== name);
    document.querySelector(`#rail [data-ws="${w}"]`)?.classList.toggle('active', w === name);
  }
  if (history.replaceState) history.replaceState(null, '', '#' + name);
  if (name === 'console') { resize(); }
  if (name === 'hub') hubLoad();
  if (name === 'code') window.dispatchEvent(new Event('tei-code-shown'));
}
document.getElementById('rail').addEventListener('click', e => {
  const b = e.target.closest('[data-ws]');
  if (b) wsShow(b.dataset.ws);
});
$('btn-open-ck')?.addEventListener('click', () => ckShow());

// ── HUB: the community store browser ─────────────────────────────────
async function hubLoad() {
  const el = $('hub-table');
  try {
    const r = await fetch(`${API_BASE}/api/calibration/reports?limit=100`).then(x => x.json());
    if (!r.count) { el.innerHTML = '<span class="text-brand-gray">no community rows yet — publish one from a CONSOLE selection.</span>'; return; }
    const rows = r.reports.slice().reverse();
    el.innerHTML = '<table class="w-full"><thead><tr class="text-brand-gray text-left">' +
      '<th class="pr-4 pb-2">board</th><th class="pr-4 pb-2">substrate</th><th class="pr-4 pb-2">prim</th>' +
      '<th class="pr-4 pb-2">J/op</th><th class="pr-4 pb-2">n_ops</th><th class="pr-4 pb-2">provenance</th><th class="pb-2">when</th></tr></thead><tbody>' +
      rows.map(x => `<tr class="border-t border-white/5">
        <td class="pr-4 py-1.5 text-brand-white">${x.board_id}</td>
        <td class="pr-4 py-1.5 text-brand-amber">${x.substrate}</td>
        <td class="pr-4 py-1.5">${x.primitive_id}</td>
        <td class="pr-4 py-1.5">${Number(x.j_per_op).toExponential(2)}</td>
        <td class="pr-4 py-1.5">${x.n_ops}</td>
        <td class="pr-4 py-1.5 text-brand-gray">${x.ledger?.joules_source || '?'}</td>
        <td class="py-1.5 text-brand-gray">${x.received_unix_ms ? new Date(x.received_unix_ms).toLocaleString() : '—'}</td></tr>`).join('') +
      '</tbody></table>';
  } catch { el.innerHTML = '<span class="text-brand-gray">store unreachable.</span>'; }
}
$('btn-hub-refresh')?.addEventListener('click', hubLoad);

// ── BUILD: the real forge ────────────────────────────────────────────
let forgeHost = null; // null until /api/forge/targets answers
async function forgeProbe() {
  try {
    const r = await fetch(`${API_BASE}/api/forge/targets`).then(x => x.json());
    forgeHost = !!r.build_host;
  } catch { forgeHost = false; }
}
forgeProbe();

$('btn-build')?.addEventListener('click', async () => {
  const t = $('build-target').value;
  const out = $('build-out');
  const src = (window.__teiAppSource && window.__teiAppSource()) || '';
  const modified = window.__teiCodeModified === true;
  if (forgeHost === null) await forgeProbe();

  if (forgeHost) {
    // real compile through the forge
    out.textContent = `forge: compiling ${t} on the build host…
(cold ~40s, warm ~2s; sandboxed, network-denied)`;
    const btn = $('btn-build'); btn.disabled = true; btn.textContent = 'BUILDING…';
    try {
      const r = await fetch(`${API_BASE}/api/forge/build`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ target: t, app_source: src }),
      });
      if (r.status === 503) { out.textContent = 'forge: this server is not a build host.'; forgeHost = false; }
      else {
        const res = await r.json();
        if (res.ok) {
          out.textContent = `forge: BUILT ${t} · ${res.uf2_family} · ${res.bytes} bytes
sha256 ${res.sha256}
→ downloading UF2; FLASH tab has the 3-step install.`;
          const a = document.createElement('a');
          a.href = `${API_BASE}/api/forge/artifact?h=${res.sha256}`; a.download = `teios-${t}.uf2`; a.click();
        } else {
          out.textContent = `forge: BUILD FAILED — ${res.error || 'error'}

${(res.logs || '').slice(-2000)}`;
        }
      }
    } catch (e) { out.textContent = 'forge: ' + (e?.message || e); }
    btn.disabled = false; btn.textContent = 'BUILD →';
    return;
  }

  // no build host (e.g. the public studio with no toolchain): the
  // unmodified template maps to the shipped tested image; modified
  // source needs a build host.
  if (!modified) {
    const file = t === 'pico2' ? '/teios/teios-pico2.uf2' : (t === 'pico' ? '/teios/teios-pico.uf2' : '/teios/teios-feather-rp2040.uf2');
    out.textContent = `no build host connected — but your source matches the shipped template for ${t}, so here is the tested image (identical build).
sha256 + size: /teios/manifest.json
→ downloading; FLASH tab has the 3-step install.`;
    const a = document.createElement('a'); a.href = file; a.download = ''; a.click();
  } else {
    out.textContent = `no build host connected. Your app.rs differs from the template, so it needs the forge build service (sandboxed per-job cargo).
Point Studio at a build host with ?api=http://host:9651, or run locally: embedded/teios-app-rp2040 (two commands in its README).`;
  }
});

// default workspace from hash; CONSOLE is the proof-of-life default.
// hashchange covers same-document navigation (back/forward, deep links).
wsShow((location.hash || '#console').slice(1));
window.addEventListener('hashchange', () => wsShow((location.hash || '#console').slice(1)));

resize();
</script>

<script>
// CODE workspace: CodeMirror 6 (bundled, self-hosted — no CDN)
import { EditorView, basicSetup } from 'codemirror';
import { rust } from '@codemirror/lang-rust';
import { EditorState } from '@codemirror/state';

const TEMPLATE = `//! your app on teiOS — scheduled, ledgered, dispatched.
//!
//! This is the E1 demo app: race CRC32 over a 64 KiB buffer on every
//! substrate the board has, price both from the cost table, dispatch
//! to the cheapest, stream the ledgers. Edit it; the forge builds it.

use teios::{app, Primitive, Ledger};

#[app::main]
async fn main(mut tei: app::Tei) {
    let buf = tei.pattern_buffer(64 * 1024);
    loop {
        // run on every substrate the cost table knows for this primitive
        let cpu: Ledger = tei.run_on("cpu", Primitive::HASH, &buf).await;
        let dma: Ledger = tei.run_on("dma-sniffer", Primitive::HASH, &buf).await;
        tei.check(cpu.result == dma.result);

        // THE dispatch rule: lowest measured joule wins
        let chosen = tei.cheapest(Primitive::HASH);
        tei.dispatch_line(chosen);

        tei.sleep_ms(1000).await;
    }
}
`;
const KEY = 'teios-app-src-v0';
const saved = localStorage.getItem(KEY);
const startDoc = saved ?? TEMPLATE;

const view = new EditorView({
  parent: document.getElementById('code-editor'),
  state: EditorState.create({
    doc: startDoc,
    extensions: [
      basicSetup, rust(),
      EditorView.theme({
        '&': { backgroundColor: 'rgba(0,0,0,0.35)', maxHeight: '520px' },
        '.cm-content': { fontFamily: '"JetBrains Mono", monospace', fontSize: '13px' },
        '.cm-gutters': { backgroundColor: 'transparent', border: 'none', color: '#475569' },
      }, { dark: true }),
      EditorView.updateListener.of(u => {
        if (u.docChanged) {
          const src = u.state.doc.toString();
          localStorage.setItem(KEY, src);
          window.__teiCodeModified = src !== TEMPLATE;
          const st = document.getElementById('code-state');
          if (st) st.textContent = window.__teiCodeModified ? 'modified — builds via forge service' : 'template — maps to shipped image';
        }
      }),
    ],
  }),
});
// expose live source to the BUILD tab (these are separate module scripts)
window.__teiAppSource = () => view.state.doc.toString();
window.__teiCodeModified = startDoc !== TEMPLATE;
const st = document.getElementById('code-state');
if (st) st.textContent = window.__teiCodeModified ? 'modified — builds via forge service' : 'template — maps to shipped image';
document.getElementById('btn-code-reset')?.addEventListener('click', () => {
  view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: TEMPLATE } });
});
</script>

</Layout>
