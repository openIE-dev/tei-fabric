    const d = new URLSearchParams(location.search).get('d');
    if (d && !diagramApplied) { diagramApplied = true; diagramApply(d); } else boardLoad();
  });
  if (name === 'code') window.dispatchEvent(new Event('tei-code-shown'));
}
document.getElementById('rail').addEventListener('click', e => {
