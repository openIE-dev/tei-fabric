$('btn-hub-refresh')?.addEventListener('click', hubLoad);

// ── BOARD: visual board view (chipdb-driven pinout + digital twin) ────
let boardLoaded = null;
async function boardPopulate() {
  const sel = $('board-select'); if (!sel || sel.options.length) return;
  try {
    const r = await fetch(`${API_BASE}/api/forge/board-list`).then(x => x.json());
    const mk = (label) => { const g = document.createElement('optgroup'); g.label = label; return g; };
    const forge = mk('forge targets (buildable)'), bench = mk('bench boards (view-only)');
    for (const b of (r.boards || [])) {
      const o = document.createElement('option');
      o.value = b.id; o.textContent = b.name ? (b.chip ? `${b.name} · ${b.chip}` : b.name) : b.id;
      (b.kind === 'bench' ? bench : forge).appendChild(o);
    }
    if (forge.children.length) sel.appendChild(forge);
    if (bench.children.length) sel.appendChild(bench);
    sel.addEventListener('change', () => boardLoad(sel.value));
  } catch {}
}
async function boardLoad(id) {
  if (!id) { const s = $('board-select'); id = s && s.value; }
  if (!id || id === boardLoaded) return;
  boardLoaded = id;
  // new board → reset peripheral mapping + load its saved placement layout
  periphAttached.length = 0; periphBoardKinds = new Set(); placementLoad(); periphSearchInit(); periphRender();
  let b;
  try { b = await fetch(`${API_BASE}/api/forge/board?id=${encodeURIComponent(id)}`).then(x => x.json()); }
  catch { $('board-ident').innerHTML = '<span class="text-brand-gray">board service unreachable.</span>'; return; }
  // shared manifest (board image / pinout-diagram fallbacks)
  if (boardManifest === null) {
    try { boardManifest = await fetch('/boards/manifest.json').then(x => x.json()); } catch { boardManifest = {}; }
  }
  const mentry = (boardManifest.boards && boardManifest.boards[id]) || {};

  $('board-ident').innerHTML = [
    ['name', b.name], ['vendor', b.vendor], ['chip', b.chip],
    ['family', b.chip_family], ['clock', b.clock_mhz ? b.clock_mhz + ' MHz' : null],
    ['price', b.price_usd ? '$' + b.price_usd.toFixed(2) : null],
    ['joules', b.energy_how],
  ].filter(([, v]) => v).map(([k, v]) =>
    `<div class="flex justify-between gap-3"><span class="text-brand-gray uppercase text-[10px] tracking-wider pt-0.5">${k}</span><span class="text-brand-white text-right">${v}</span></div>`
  ).join('')
    + (b.carrier_note ? `<p class="mt-2 text-brand-gray text-[10px] leading-snug border-l-2 border-brand-amber/40 pl-2">${b.carrier_note}</p>` : '')
    + (b.url ? `<a href="${b.url}" target="_blank" rel="noopener" class="block mt-2 text-brand-amber text-[11px] hover:underline">product page ↗</a>` : '');

  boardModel(id);

  const po = $('board-pinout'), lg = $('board-legend');
  if (!b.pinout) {
    if (mentry.pinout_image) {
      // no structured pin map, but the vendor publishes a pinout diagram
      po.innerHTML = `<img src="/boards/${mentry.pinout_image}" alt="${id} pinout" loading="lazy" style="width:100%;border-radius:8px;background:#fff" />
        <p class="text-brand-gray text-[10px] mt-2">vendor pinout diagram — structured (color-coded) map not transcribed yet</p>`;
    } else {
      po.innerHTML = '<span class="text-brand-gray">Identity only — no datasheet-verified pin map for this board yet. (We don\'t guess pinouts.)</span>';
    }
    lg.innerHTML = ''; periphBoardKinds = new Set(); boardPins = []; periphRender(); return;
  }
  // dual-column physical layout: first half down the left, second half down the right.
  const pins = b.pinout.pins, half = Math.ceil(pins.length / 2);
  const left = pins.slice(0, half), right = pins.slice(half);
  const pinRow = (p, flip) => {
    const dot = `<span class="inline-block w-2.5 h-2.5 rounded-full shrink-0" style="background:${p.color}"></span>`;
    const num = `<span class="text-brand-gray w-6 ${flip ? 'text-left' : 'text-right'} shrink-0">${p.number}</span>`;
    const nm = `<span class="text-brand-white truncate" title="${(p.functions||[]).join(' · ')}">${p.name}</span>`;
    const fns = `<span class="text-brand-gray/60 truncate text-[10px]" title="${(p.functions||[]).join(' · ')}">${(p.functions||[]).join(' ')}</span>`;
    return flip
      ? `<div class="flex items-center gap-2 py-0.5">${num}${dot}${nm}<span class="flex-1"></span>${fns}</div>`
      : `<div class="flex items-center gap-2 py-0.5">${fns}<span class="flex-1"></span>${nm}${dot}${num}</div>`;
  };
  po.innerHTML = `<div class="grid grid-cols-2 gap-x-6">
    <div>${left.map(p => pinRow(p, false)).join('')}</div>
    <div>${right.map(p => pinRow(p, true)).join('')}</div></div>`;

  // legend: distinct kinds present
  const seen = new Map();
  for (const p of pins) if (!seen.has(p.kind)) seen.set(p.kind, p.color);
  lg.innerHTML = [...seen].map(([k, c]) =>
    `<span class="flex items-center gap-1.5 text-[10px] text-brand-gray"><span class="inline-block w-2.5 h-2.5 rounded-full" style="background:${c}"></span>${k}</span>`).join('');

  // the buses this board exposes (drives peripheral compatibility + wiring)
  periphBoardKinds = new Set([...seen.keys()]);
  boardPins = pins;
  periphRender();
}

// ── peripheral mapping (open ECAD parts library — ecad.openie.dev) ────
const ECAD_API = 'https://ecad.openie.dev/api/v1';
const periphAttached = [];          // [{mpn, name, iface, pins, datasheet}]
let periphBoardKinds = new Set();   // bus kinds the current board exposes
let boardPins = [];                 // the current board's pins (for wiring)

// pick concrete board pins for an interface, by matching pin functions/names.
function wiringFor(iface) {
  const find = re => { const p = boardPins.find(x => re.test(`${x.name} ${(x.functions||[]).join(' ')}`)); return p ? p.name : null; };
  const pwr = (boardPins.find(x => /3V?3|3\.3/.test(x.name)) || boardPins.find(x => x.kind === 'Power')) || null;
  const gnd = boardPins.find(x => x.kind === 'Ground') || null;
  const w = [];
  if (pwr) w.push(['VCC', pwr.name]);
  if (gnd) w.push(['GND', gnd.name]);
  if (iface === 'I2C') { const a = find(/SDA/i), b = find(/SCL/i); if (a) w.push(['SDA', a]); if (b) w.push(['SCL', b]); }
  else if (iface === 'SPI') { const sck = find(/SCK/i), mo = find(/MOSI|\bMO\b|SPI\d? TX/i), mi = find(/MISO|\bMI\b|SPI\d? RX/i), cs = find(/\bCSn?\b/i);
    if (sck) w.push(['SCK', sck]); if (mo) w.push(['MOSI', mo]); if (mi) w.push(['MISO', mi]); if (cs) w.push(['CS', cs]); }
  else if (iface === 'UART') { const tx = find(/UART\d? TX|\bTX\b/i), rx = find(/UART\d? RX|\bRX\b/i); if (tx) w.push(['→RX', tx]); if (rx) w.push(['←TX', rx]); }
  else if (iface === 'ADC') { const a = (boardPins.find(x => x.kind === 'ADC')); if (a) w.push(['AOUT', a.name]); }
  else { const g = (boardPins.find(x => x.kind === 'GPIO')); if (g) w.push(['IO', g.name]); }
  return w;
}

// infer the coding interface from a part's category/description/pins
function inferIface(c) {
  const s = `${c.category || ''} ${c.description || ''} ${(c.pin_names || []).join(' ')}`.toLowerCase();
  if (/\bi2c\b|\bsda\b|\bscl\b/.test(s)) return 'I2C';
  if (/\bspi\b|\bmosi\b|\bmiso\b|\bsck\b|\bcs\b/.test(s)) return 'SPI';
  if (/\buart\b|\btx\b|\brx\b|serial/.test(s)) return 'UART';
  if (/\badc\b|analog/.test(s)) return 'ADC';
  if (/1-?wire|onewire/.test(s)) return 'GPIO';
  return 'GPIO';
}
const IFACE_TO_KIND = { I2C: 'I²C', SPI: 'SPI', UART: 'UART', ADC: 'ADC', GPIO: 'GPIO' };

let periphTimer = null;
function periphSearchInit() {
  const inp = $('periph-search'); if (!inp || inp._wired) return; inp._wired = true;
  inp.addEventListener('input', () => {
    clearTimeout(periphTimer);
    periphTimer = setTimeout(() => periphSearch(inp.value.trim()), 300);
  });
}
async function periphSearch(q) {
  const el = $('periph-results'); if (!el) return;
  if (q.length < 2) { el.innerHTML = ''; return; }
  el.innerHTML = '<span class="text-brand-gray">searching…</span>';
  try {
    const hits = await fetch(`${ECAD_API}/search?q=${encodeURIComponent(q)}&limit=8`).then(r => r.json());
    const comps = (hits || []).filter(h => h.item_type === 'component').slice(0, 8);
    if (!comps.length) { el.innerHTML = '<span class="text-brand-gray">no parts found.</span>'; return; }
    el.innerHTML = comps.map(h =>
      `<button data-id="${h.item_id}" data-mpn="${h.mpn || ''}" class="periph-add block w-full text-left px-2 py-1 rounded hover:bg-white/5">
         <span class="text-brand-amber">+ ${h.mpn || h.name}</span>
         <span class="text-brand-gray"> · ${(h.description || h.name || '').slice(0, 60)}</span></button>`).join('');
    el.querySelectorAll('.periph-add').forEach(b => b.addEventListener('click', () => periphAttach(b.dataset.id)));
  } catch { el.innerHTML = '<span class="text-brand-gray">parts library unreachable.</span>'; }
}
async function periphAttach(id) {
  try {
    const c = await fetch(`${ECAD_API}/components/${encodeURIComponent(id)}`).then(r => r.json());
    if (!c || !c.mpn) return;
    if (periphAttached.some(p => p.mpn === c.mpn)) return;
    periphAttached.push({
      mpn: c.mpn, name: c.description || c.mpn, iface: inferIface(c),
      pins: c.pin_names || [], datasheet: c.datasheet_url || null,
      model_3d: c.model_3d && !`${JSON.stringify(c.model_3d)}`.match(/null|"None"/) ? c.model_3d : null,
    });
    $('periph-results').innerHTML = ''; $('periph-search').value = '';
    periphRender();
  } catch {}
}
function periphRender() {
  const att = $('periph-attached'), tc = $('periph-tocode');
  if (!att) return;
  att.innerHTML = periphAttached.map((p, i) => {
    const onBoard = periphBoardKinds.has(IFACE_TO_KIND[p.iface]);
    const wires = wiringFor(p.iface);
    const wiring = wires.length
      ? `<div class="flex flex-wrap gap-x-3 gap-y-0.5 mt-1 pl-1 text-[10px] text-brand-gray">
          ${wires.map(([sig, pin]) => `<span><span class="text-brand-cyan">${sig}</span>→<span class="text-brand-light">${pin}</span></span>`).join('')}
        </div>` : '';
    return `<div class="bg-black/30 rounded-lg px-2.5 py-1.5">
      <div class="flex items-center gap-2 text-[11px]">
        <span class="font-mono px-1.5 py-0.5 rounded text-[10px] ${onBoard ? 'bg-brand-cyan/15 text-brand-cyan' : 'bg-brand-amber/15 text-brand-amber'}">${p.iface}</span>
        <span class="text-brand-white">${p.mpn}</span>
        <span class="text-brand-gray truncate flex-1">${p.name}</span>
        ${p.datasheet ? `<a href="${p.datasheet}" target="_blank" rel="noopener" class="text-brand-gray hover:text-brand-amber">ds↗</a>` : ''}
        <button data-i="${i}" class="periph-del text-brand-gray hover:text-red-400">✕</button>
      </div>${wiring}
    </div>`;
  }).join('');
  att.querySelectorAll('.periph-del').forEach(b => b.addEventListener('click', () => { periphAttached.splice(+b.dataset.i, 1); periphRender(); }));

  if (!periphAttached.length) { tc.innerHTML = ''; return; }
  // "what needs coding": one bus init per distinct interface + a driver per part
  const buses = [...new Set(periphAttached.map(p => p.iface))];
  const tasks = buses.map(bus => {
    const parts = periphAttached.filter(p => p.iface === bus).map(p => p.mpn);
    const have = periphBoardKinds.has(IFACE_TO_KIND[bus]);
    return `<li>${have ? '' : '⚠ '}init <span class="text-brand-light">${bus}</span>${have ? '' : ' (no ' + bus + ' pin on this board?)'} → driver${parts.length > 1 ? 's' : ''}: <span class="text-brand-amber">${parts.join(', ')}</span></li>`;
  });
  tc.innerHTML = `<p class="text-brand-gray uppercase text-[10px] tracking-wider mb-1.5">what needs coding</p>
    <ul class="space-y-1 list-disc list-inside text-brand-gray">${tasks.join('')}</ul>`;
  placementRender();
}

// ── placement map: spatial canvas — drag board + peripherals, draw wiring ─
const IFACE_COLOR = { 'I²C': '#3b82f6', I2C: '#3b82f6', SPI: '#f0883e', UART: '#a371f7', ADC: '#2dd4bf', GPIO: '#3fb950' };
let placementPos = {};   // key -> {x,y} (board key = '_board', peripherals = mpn)
function placementKey() { return 'tei-placement-' + (boardLoaded || 'none'); }
function placementLoad() { try { placementPos = JSON.parse(localStorage.getItem(placementKey()) || '{}'); } catch { placementPos = {}; } }
function placementSave() { try { localStorage.setItem(placementKey(), JSON.stringify(placementPos)); } catch {} }
function placementRender() {
  const cv = $('placement-canvas'); if (!cv) return;
  const W = cv.clientWidth || 600, H = cv.clientHeight || 380;
  const nodes = [{ key: '_board', label: boardLoaded || 'board', kind: 'board' }]
    .concat(periphAttached.map(p => ({ key: p.mpn, label: p.mpn, kind: 'periph', iface: p.iface })));
  // default positions: board left-center, peripherals fanned on the right
  nodes.forEach((n, i) => {
    if (!placementPos[n.key]) {
      placementPos[n.key] = n.kind === 'board'
        ? { x: 40, y: H / 2 - 26 }
        : { x: W - 200, y: 30 + (i - 1) * 64 };
    }
  });
  // SVG wiring under the nodes
  const lines = periphAttached.map(p => {
    const a = placementPos['_board'], b = placementPos[p.mpn]; if (!a || !b) return '';
    const x1 = a.x + 70, y1 = a.y + 26, x2 = b.x + 6, y2 = b.y + 18;
    const mx = (x1 + x2) / 2, col = IFACE_COLOR[p.iface] || '#64748b';
    return `<path d="M${x1},${y1} C${mx},${y1} ${mx},${y2} ${x2},${y2}" fill="none" stroke="${col}" stroke-width="1.5" opacity="0.8"/>
      <text x="${mx}" y="${(y1 + y2) / 2 - 4}" fill="${col}" font-size="9" text-anchor="middle" font-family="monospace">${p.iface}</text>`;
  }).join('');
  const nodeHtml = nodes.map(n => {
    const pos = placementPos[n.key];
    const isBoard = n.kind === 'board';
    const col = isBoard ? '#F59E0B' : (IFACE_COLOR[n.iface] || '#64748b');
    return `<div class="placement-node absolute select-none cursor-grab active:cursor-grabbing" data-key="${n.key}"
        style="left:${pos.x}px;top:${pos.y}px;${isBoard ? 'width:140px;height:52px' : 'min-width:84px;height:36px'}">
        <div class="rounded-lg border px-2 py-1 font-mono text-[10px] flex items-center justify-center text-center h-full"
          style="border-color:${col};background:${col}1a;color:${col}">${n.label}</div>
      </div>`;
  }).join('');
  cv.innerHTML = `<svg class="absolute inset-0 w-full h-full pointer-events-none">${lines}</svg>${nodeHtml}`;
  cv.querySelectorAll('.placement-node').forEach(el => placementDrag(el, cv));
}
function placementDrag(el, cv) {
  el.addEventListener('pointerdown', e => {
    e.preventDefault(); el.setPointerCapture(e.pointerId);
    const k = el.dataset.key, start = placementPos[k], sx = e.clientX, sy = e.clientY;
    const move = ev => {
      placementPos[k] = { x: Math.max(0, start.x + ev.clientX - sx), y: Math.max(0, start.y + ev.clientY - sy) };
      el.style.left = placementPos[k].x + 'px'; el.style.top = placementPos[k].y + 'px';
      // redraw only the wiring (cheap) — re-render lines from current positions
      const svg = cv.querySelector('svg'); if (svg) placementRedrawLines(svg);
    };
    const up = ev => { el.releasePointerCapture(e.pointerId); el.removeEventListener('pointermove', move); el.removeEventListener('pointerup', up); placementSave(); };
    el.addEventListener('pointermove', move); el.addEventListener('pointerup', up);
  });
}
function placementRedrawLines(svg) {
  svg.innerHTML = periphAttached.map(p => {
    const a = placementPos['_board'], b = placementPos[p.mpn]; if (!a || !b) return '';
    const x1 = a.x + 70, y1 = a.y + 26, x2 = b.x + 6, y2 = b.y + 18, mx = (x1 + x2) / 2, col = IFACE_COLOR[p.iface] || '#64748b';
    return `<path d="M${x1},${y1} C${mx},${y1} ${mx},${y2} ${x2},${y2}" fill="none" stroke="${col}" stroke-width="1.5" opacity="0.8"/>
      <text x="${mx}" y="${(y1 + y2) / 2 - 4}" fill="${col}" font-size="9" text-anchor="middle" font-family="monospace">${p.iface}</text>`;
  }).join('');
}
document.getElementById('placement-reset')?.addEventListener('click', () => { placementPos = {}; placementSave(); placementRender(); });

// ── shareable diagram: encode board + peripherals + layout into a link ──
// var (not let): a shared link loads with #board, so the initial wsShow may
// read this flag before this line executes — var hoists undefined (falsy), so
// the apply path still fires correctly and never hits a TDZ ReferenceError.
var diagramApplied = false;
function b64urlEnc(s) { return btoa(unescape(encodeURIComponent(s))).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, ''); }
function b64urlDec(s) { s = s.replace(/-/g, '+').replace(/_/g, '/'); return decodeURIComponent(escape(atob(s))); }
function diagramState() {
  const bp = placementPos['_board'] || {};
  return {
    b: boardLoaded,
    bx: bp.x, by: bp.y,
    p: periphAttached.map(p => { const pos = placementPos[p.mpn] || {}; return { m: p.mpn, n: p.name, i: p.iface, x: pos.x, y: pos.y }; }),
  };
}
function diagramShare() {
  if (!boardLoaded) return;
  const enc = b64urlEnc(JSON.stringify(diagramState()));
  const url = `${location.origin}${location.pathname}?d=${enc}#board`;
  history.replaceState(null, '', `?d=${enc}#board`);
  const done = () => { const m = $('diagram-share-msg'); if (m) { m.textContent = 'link copied'; setTimeout(() => { m.textContent = ''; }, 2500); } };
  if (navigator.clipboard?.writeText) navigator.clipboard.writeText(url).then(done, done); else done();
}
async function diagramApply(enc) {
  let st; try { st = JSON.parse(b64urlDec(enc)); } catch { return false; }
  if (!st || !st.b) return false;
  const sel = $('board-select'); if (sel) sel.value = st.b;
  await boardLoad(st.b);                 // identity/pinout/3D/boardPins (resets peripherals)
  // peripherals straight from the link — self-contained, no parts-service fetch
  periphAttached.length = 0;
  for (const p of (st.p || [])) periphAttached.push({ mpn: p.m, name: p.n || p.m, iface: p.i || 'GPIO', pins: [], datasheet: null });
  if (st.bx != null) placementPos['_board'] = { x: st.bx, y: st.by };
  for (const p of (st.p || [])) if (p.x != null) placementPos[p.m] = { x: p.x, y: p.y };
  periphRender();                        // peripherals + wiring + placementRender
  return true;
}
$('diagram-share')?.addEventListener('click', diagramShare);

// ── board 3D model + datasheet (vendor CAD → glTF, built offline) ─────
let boardManifest = null;
async function boardModel(id) {
  const view = $('board-model-view'), links = $('board-model-links');
  if (!view || !links) return;
  if (boardManifest === null) {
    try { boardManifest = await fetch('/boards/manifest.json').then(x => x.json()); }
    catch { boardManifest = {}; }
  }
  const entry = (boardManifest.boards && boardManifest.boards[id]) || {};
  // datasheet + vendor CAD source links (real, from the manifest)
  const L = [];
  if (entry.datasheet) L.push(`<a href="${entry.datasheet}" target="_blank" rel="noopener" class="block text-brand-amber text-[11px] hover:underline">datasheet (PDF) ↗</a>`);
  if (entry.cad_step) L.push(`<a href="${entry.cad_step}" target="_blank" rel="noopener" class="block text-brand-gray text-[11px] hover:underline">vendor 3D CAD (STEP) ↗</a>`);
  links.innerHTML = L.join('');

  // probe the built glTF; render inline if present + a viewer is available
  let has = false;
  try { has = (await fetch(`/boards/${id}.glb`, { method: 'HEAD' })).ok; } catch {}
  if (has) {
    // lazy-load the self-hosted model-viewer ESM only when a 3D board is
    // actually viewed (the bundle is ~1 MB — never on first page load).
    if (!(window.customElements && customElements.get('model-viewer'))) {
      try { await import('/vendor/model-viewer.min.js'); } catch {}
    }
    if (window.customElements && customElements.get('model-viewer')) {
      view.innerHTML = `<model-viewer src="/boards/${id}.glb" camera-controls auto-rotate touch-action="pan-y"
        style="width:100%;height:240px;background:#0a0d16;border-radius:8px" exposure="0.9" shadow-intensity="0.4"></model-viewer>`;
    } else {
      view.innerHTML = `<a href="/boards/${id}.glb" target="_blank" rel="noopener" class="text-brand-cyan text-[11px] hover:underline">↗ view 3D model (.glb)</a>`;
    }
  } else if (entry.image) {
    // no glTF, but the vendor publishes a board photo — show it.
    view.innerHTML = `<img src="/boards/${entry.image}" alt="${id} board photo" loading="lazy"
      style="width:100%;border-radius:8px;background:#0a0d16" />`;
  } else {
    view.innerHTML = `<p class="text-brand-gray text-[11px]">3D model pending — convert the vendor STEP:
      <span class="text-brand-light">web/scripts/build-board-assets.sh</span></p>`;
  }
}

// ── digital twin: a live mirror of the running device's internal work ─
// Honest scope: the ledger reports SUBSTRATE-level activity (which engine
// ran, cycles, joules, the dispatch verdict) — not pin-level signals — so
// the twin animates the live execution, not pins it can't observe.
const twinStats = new Map(); // substrate -> {lastMs, cycles, joules, ticks}
function twinSetConnected(on) {
  const el = $('board-twin'); if (!el) return;
  el.textContent = on ? '● live' : '○ not connected';
  el.className = el.className.replace(/text-(brand-\w+)/g, '').trimEnd() + (on ? ' text-brand-cyan' : ' text-brand-gray');
}
function twinSpark(st) {
  // mini sparkline of recent activity — cycles (always reported by the
  // device) so the twin moves even when joules are unpriced on-device.
  const v = st.hist || [];
  if (v.length < 2) return '';
  const max = Math.max(...v), min = Math.min(...v), span = (max - min) || 1, W = 72, H = 16;
  const d = v.map((x, i) => `${(i / (v.length - 1) * W).toFixed(1)},${(H - (x - min) / span * H).toFixed(1)}`).join(' ');
  return `<svg width="${W}" height="${H}" class="shrink-0"><polyline points="${d}" fill="none" stroke="currentColor" stroke-width="1" opacity="0.7"/></svg>`;
}
function twinRender() {
  const el = $('board-twin-activity'); if (!el) return;
  if (!twinStats.size) return;
  const chosen = (typeof lastDispatch !== 'undefined' && lastDispatch) ? lastDispatch.chosen : null;
  const now = Date.now();
  const rows = [...twinStats.entries()].sort((a, b) => a[0].localeCompare(b[0])).map(([s, st]) => {
    const age = now - st.lastMs;
    const live = age < 800;            // just ticked → pulse
    const stale = age > 4000;          // gone quiet → dim
    const isCh = s === chosen;
    const dot = live
      ? `<span class="relative flex w-2.5 h-2.5"><span class="animate-ping absolute inline-flex h-full w-full rounded-full ${isCh ? 'bg-brand-amber' : 'bg-brand-cyan'} opacity-75"></span><span class="relative inline-flex rounded-full w-2.5 h-2.5 ${isCh ? 'bg-brand-amber' : 'bg-brand-cyan'}"></span></span>`
      : `<span class="inline-block w-2.5 h-2.5 rounded-full ${isCh ? 'bg-brand-amber' : 'bg-brand-cyan/40'}"></span>`;
    return `<div class="flex items-center gap-2 py-1 ${stale ? 'opacity-40' : ''}">
        ${dot}
        <span class="${isCh ? 'text-brand-amber' : 'text-brand-light'} w-32 truncate">${s}</span>
        <span class="text-brand-gray text-[10px] w-20 text-right">${st.cycles != null ? st.cycles.toLocaleString() + ' cyc' : '—'}</span>
        <span class="text-brand-gray text-[10px] w-20 text-right">${st.joules ? st.joules.toExponential(1) + ' J' : ''}</span>
        <span class="${isCh ? 'text-brand-amber' : 'text-brand-cyan'} ml-auto">${twinSpark(st)}</span>
        ${isCh ? '<span class="text-brand-amber text-[10px] shrink-0">dispatched</span>' : ''}
      </div>`;
  }).join('');
  el.innerHTML = `<div class="flex items-center justify-between mb-1.5 text-[10px] text-brand-gray uppercase tracking-wider">
      <span>substrate</span><span>live execution mirror</span></div>${rows}`;
}
function twinLedger(substrate, ledger) {
  if (!substrate) return;
  const st = twinStats.get(substrate) || { joules: 0, ticks: 0, hist: [] };
  st.lastMs = Date.now();
  st.cycles = ledger && ledger.cycles != null ? ledger.cycles : st.cycles;
  if (ledger && ledger.joules != null) st.joules += ledger.joules;
  if (st.cycles != null) { st.hist.push(st.cycles); if (st.hist.length > 24) st.hist.shift(); }
  st.ticks++;
  twinStats.set(substrate, st);
  twinSetConnected(true);
  twinRender();
}
function twinDispatch() { twinRender(); }
// keep the pulse/decay animating while the BOARD tab is open
setInterval(() => {
  if (!document.getElementById('ws-board')?.classList.contains('hidden')) twinRender();
}, 400);

// ── BUILD: the real forge ────────────────────────────────────────────
let forgeHost = null; // null until /api/forge/targets answers
async function forgeProbe() {
  try {
    const r = await fetch(`${API_BASE}/api/forge/targets`).then(x => x.json());
    forgeHost = !!r.build_host;
    // Board identity is sourced from ofpga-chipdb (the single registry):
    // relabel each forge target's dropdown option with the chipdb name +
    // chip. Options without an API entry (e.g. pico2) are left untouched.
    const sel = $('build-target');
    for (const t of (r.targets || [])) {
      const opt = sel && [...sel.options].find(o => o.value === t.id);
      if (opt && t.name) opt.textContent = t.chip ? `${t.name} · ${t.chip}` : t.name;
      // Record measured-joules capability so the checkbox can disable
      // itself on targets without an embedded-hal I²C path (e.g. RA6M5).
      measuredByTarget[t.id] = !!t.measured;
    }
    syncMeasured();
  } catch { forgeHost = false; }
}
// Which targets can build the Measured variant (from /api/forge/targets).
const measuredByTarget = {};
function syncMeasured() {
  const t = $('build-target')?.value;
  const cb = $('build-measured');
  const na = $('build-measured-na');
  if (!cb) return;
  // Default unknown targets to capable (the server is the source of truth
  // at build time; this only governs the checkbox UX).
  const ok = measuredByTarget[t] !== false;
  cb.disabled = !ok;
  if (!ok) cb.checked = false;
  na?.classList.toggle('hidden', ok);
  $('build-measured-row')?.classList.toggle('opacity-50', !ok);
}
$('build-target')?.addEventListener('change', syncMeasured);
forgeProbe();

$('btn-build')?.addEventListener('click', async () => {
  const t = $('build-target').value;
  const out = $('build-out');
  const measured = !!$('build-measured')?.checked && measuredByTarget[t] !== false;
  const src = (window.__teiAppSource && window.__teiAppSource()) || '';
  const modified = window.__teiCodeModified === true;
  if (forgeHost === null) await forgeProbe();

  if (forgeHost) {
    // real compile through the forge
    out.textContent = `forge: compiling ${t}${measured ? ' (measured · INA228)' : ''} on the build host…
(cold ~40s, warm ~2s; sandboxed, network-denied)`;
    const btn = $('btn-build'); btn.disabled = true; btn.textContent = 'BUILDING…';
    try {
      const r = await fetch(`${API_BASE}/api/forge/build`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ target: t, app_source: src, measured }),
      });
      if (r.status === 503) { out.textContent = 'forge: this server is not a build host.'; forgeHost = false; }
      else {
        const res = await r.json();
        if (res.ok) {
          const ext = res.artifact_ext || 'uf2';
          let flashHint;
          if (ext !== 'bin') {
            flashHint = `→ downloading UF2; FLASH tab has the 3-step install.`;
          } else if (res.uf2_family === 'nrf52832') {
            flashHint = `→ downloading .bin (nRF52832 · ledger streams over UART @115200, not USB):\n  probe-rs download --chip nRF52832_xxAA --binary-format bin --base-address 0x0 teios-${t}.bin`;
          } else if (res.uf2_family === 'ra6m5') {
            flashHint = `→ downloading .bin (RA6M5 · ledger streams over semihosting to the debug probe):\n  probe-rs download --chip R7FA6M5BH --binary-format bin --base-address 0x0 teios-${t}.bin`;
          } else {
            flashHint = `→ downloading .bin; flash via DFU (double-tap reset):\n  dfu-util -d 2341:035b -a 0 -s 0x08040000:leave -D teios-${t}.bin`;
          }
          const measuredNote = measured
            ? `\nmeasured: INA228 EnergyMeter compiled in → ledger reports JoulesSource::Measured.\n  wire the part in-line on the supply rail (default 0x40, 0.015 Ω shunt).`
            : '';
          out.textContent = `forge: BUILT ${t}${measured ? ' (measured)' : ''} · ${res.uf2_family} · ${res.bytes} bytes
sha256 ${res.sha256}${measuredNote}
${flashHint}`;
          const a = document.createElement('a');
          a.href = `${API_BASE}/api/forge/artifact?h=${res.sha256}`; a.download = `teios-${t}.${ext}`; a.click();
        } else {
          out.textContent = `forge: BUILD FAILED — ${res.error || 'error'}

${(res.logs || '').slice(-2000)}`;
        }
      }
    } catch (e) { out.textContent = 'forge: ' + (e?.message || e); }
    btn.disabled = false; btn.textContent = 'BUILD →';
    return;
  }

  // no build host (e.g. the public studio with no toolchain): the
  // unmodified template maps to the shipped tested image; modified
  // source needs a build host. Only the RP2040/RP2350 images ship
  // pre-built — H7 (.bin) always needs the forge.
  if (t.startsWith('portenta-') || t.startsWith('nicla-')) {
    out.textContent = `no build host connected. ${t} is built by the forge (cross-compiled to a .bin) — there is no pre-shipped image.
Point Studio at a build host with ?api=http://host:9651 (studio.thermoedge.ai is one).`;
  } else if (!modified) {
    const file = t === 'pico2' ? '/teios/teios-pico2.uf2' : (t === 'pico' ? '/teios/teios-pico.uf2' : '/teios/teios-feather-rp2040.uf2');
    out.textContent = `no build host connected — but your source matches the shipped template for ${t}, so here is the tested image (identical build).
sha256 + size: /teios/manifest.json
→ downloading; FLASH tab has the 3-step install.`;
    const a = document.createElement('a'); a.href = file; a.download = ''; a.click();
  } else {
    out.textContent = `no build host connected. Your app.rs differs from the template, so it needs the forge build service (sandboxed per-job cargo).
Point Studio at a build host with ?api=http://host:9651, or run locally: embedded/teios-app-rp2040 (two commands in its README).`;
  }
});

// default workspace from hash; CONSOLE is the proof-of-life default.
// hashchange covers same-document navigation (back/forward, deep links).
wsShow((location.hash || '#console').slice(1));
window.addEventListener('hashchange', () => wsShow((location.hash || '#console').slice(1)));

resize();
</script>

<script>
// CODE workspace: CodeMirror 6 (bundled, self-hosted — no CDN)
import { EditorView, basicSetup } from 'codemirror';
import { rust } from '@codemirror/lang-rust';
import { EditorState } from '@codemirror/state';

const TEMPLATE = `//! your app on teiOS — scheduled, ledgered, dispatched.
//!
//! This is the E1 demo app: race CRC32 over a 64 KiB buffer on every
//! substrate the board has, price both from the cost table, dispatch
//! to the cheapest, stream the ledgers. Edit it; the forge builds it.

use teios::{app, Primitive, Ledger};

#[app::main]
async fn main(mut tei: app::Tei) {
    let buf = tei.pattern_buffer(64 * 1024);
    loop {
        // run on every substrate the cost table knows for this primitive
        let cpu: Ledger = tei.run_on("cpu", Primitive::HASH, &buf).await;
        let dma: Ledger = tei.run_on("dma-sniffer", Primitive::HASH, &buf).await;
        tei.check(cpu.result == dma.result);

        // THE dispatch rule: lowest measured joule wins
        let chosen = tei.cheapest(Primitive::HASH);
        tei.dispatch_line(chosen);

        tei.sleep_ms(1000).await;
    }
}
`;
const KEY = 'teios-app-src-v0';
const saved = localStorage.getItem(KEY);
const startDoc = saved ?? TEMPLATE;

const view = new EditorView({
  parent: document.getElementById('code-editor'),
  state: EditorState.create({
    doc: startDoc,
    extensions: [
      basicSetup, rust(),
      EditorView.theme({
        '&': { backgroundColor: 'rgba(0,0,0,0.35)', maxHeight: '520px' },
        '.cm-content': { fontFamily: '"JetBrains Mono", monospace', fontSize: '13px' },
        '.cm-gutters': { backgroundColor: 'transparent', border: 'none', color: '#475569' },
      }, { dark: true }),
      EditorView.updateListener.of(u => {
        if (u.docChanged) {
          const src = u.state.doc.toString();
          localStorage.setItem(KEY, src);
          window.__teiCodeModified = src !== TEMPLATE;
          const st = document.getElementById('code-state');
          if (st) st.textContent = window.__teiCodeModified ? 'modified — builds via forge service' : 'template — maps to shipped image';
        }
      }),
    ],
  }),
});
// expose live source to the BUILD tab (these are separate module scripts)
window.__teiAppSource = () => view.state.doc.toString();
window.__teiCodeModified = startDoc !== TEMPLATE;
const st = document.getElementById('code-state');
if (st) st.textContent = window.__teiCodeModified ? 'modified — builds via forge service' : 'template — maps to shipped image';
document.getElementById('btn-code-reset')?.addEventListener('click', () => {
  view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: TEMPLATE } });
});
</script>

